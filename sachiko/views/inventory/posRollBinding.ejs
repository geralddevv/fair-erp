<% layout('/layout/boilerplate') %>
    <style>
      .pos-roll-id-success {
      border: 2px solid #28a745 !important;
      background-color: #f3fff6;
      color: #155724;
      font-weight: 600;
    }

    .pos-roll-id-error {
      border: 2px solid #dc3545 !important;
      background-color: #fff5f5;
      color: #721c24;
      font-weight: 600;
    }
    </style>

      <!-- The main content -->
      <div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
        <form action="/fairdesk/form/pos-roll-binding" method="post" onsubmit="return validatePosRollBeforeSubmit()" class="needs-validation" autocomplete="off" novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="span-full form-heading">
            <h1>Client POS Roll</h1>
          </div>

          <div class="span-full form-subheading">
            <h1>User Info</h1>
          </div>

          <div id="pos-roll-id-div" class="span-seven">
            <label for="pos-roll-id">POS Roll ID</label>
            <input type="text" id="pos-roll-id" class="form-control" name="posProductId" placeholder="Will appear here" readonly required />
          </div>                  

          <div id="client-name-div" class="span-six">
            <div class="clientName-label"><label for="client-name">Client Name</label><span class="asterisk" style="font-size: 14px;"></span></div>
            <select name="clientName" id="client-name" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% for (let client of clients) { %>
              <option value="<%= client %>"><%= client %></option>
              <% } %>
            </select>
          </div>  

          <div id="user-name-div" class="span-six">
            <label>User Name</label>
            <select id="client-user-name" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
            </select>
          </div>
          <div id="user-name-contact-div" class="span-six">
            <label for="user-contact">User Contact</label>
            <input type="text" id="user-contact" class="form-control" name="userContact" placeholder="Enter User Contact" required />
          </div>
          <div id="client-location-div" class="span-seven">
            <label for="client-location">Location</label>
            <input type="text" id="client-location" class="form-control" name="location" placeholder="Enter Location" required />
          </div>

          <div class="span-full form-subheading" style="display: flex; justify-content: space-between; align-items: center;">
            <h1>POS Roll Specifications</h1>
            <button type="button" id="reset-specs-btn" style="padding: 4px 12px; border-radius: 4px; background-color: #dc3545; color: white; border: none; cursor: pointer; font-size: 14px;">
              Reset
            </button>
          </div>

          <div class="span-five">
            <label>Paper Code</label>
            <select name="posPaperCode" id="pos-paper-code" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% paperCodes?.forEach(pc => { %>
                <option value="<%= pc %>"><%= pc %></option>
              <% }) %>
            </select>
          </div>

          <div class="span-five">
            <label>Paper Type</label>
            <select name="posPaperType" id="pos-paper-type" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% paperTypes?.forEach(pt => { %>
                <option value="<%= pt %>"><%= pt %></option>
              <% }) %>
            </select>
          </div>

          <div class="span-five">
            <label>Color</label>
            <select name="posColor" id="pos-color" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% colors?.forEach(c => { %>
                <option value="<%= c %>"><%= c %></option>
              <% }) %>
            </select>
          </div>

          <div class="span-four">
            <label>GSM</label>
            <select name="posGsm" id="pos-gsm" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% gsms?.forEach(g => { %>
                <option value="<%= g %>"><%= g %></option>
              <% }) %>
            </select>
          </div>

          <div class="span-four">
            <label>Width</label>
            <select name="posWidth" id="pos-width" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% widths?.forEach(w => { %>
                <option value="<%= w %>"><%= w %></option>
              <% }) %>
            </select>
          </div>

          <div class="span-five">
            <label>MTRS</label>
            <select name="posMtrs" id="pos-mtrs" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% mtrsList?.forEach(m => { %>
                <option value="<%= m %>"><%= m %></option>
              <% }) %>
            </select>
          </div>

          <div class="span-four">
            <label for="pos-core-id">Core ID</label>
            <select name="posCoreId" id="pos-core-id" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% coreIds?.forEach(c => { %>
                <option value="<%= c %>"><%= c %></option>
              <% }) %>
            </select>
          </div>

          <div class="span-full form-subheading">
            <h1>Client Overrides</h1>
          </div>
          
          <div class="span-seven">
            <label for="pos-client-paper-code">Client Paper Code</label>
            <input type="text" id="pos-client-paper-code" class="form-control" name="posClientPaperCode" placeholder="Enter Client Paper Code" required />
          </div>
          <div class="span-seven">
            <label for="pos-client-gsm">Client GSM</label>
            <input type="text" id="pos-client-gsm" class="form-control" name="clientPosGsm" placeholder="Enter Client GSM" required />
          </div>

          <div class="span-six">
            <label for="pos-mtrs-del">MTRS Delivered</label>
            <input type="text" id="pos-mtrs-del" class="form-control" name="posMtrsDel" placeholder="Enter MTRS Delivered" required />
          </div>          
          <div class="span-six">
            <label for="pos-rate-per-roll">Rate Per Roll</label>
            <input type="text" id="pos-rate-per-roll" class="form-control" name="posRatePerRoll" placeholder="Enter rate per roll" required />
          </div>            
          <div class="span-six">
            <label for="pos-sale-cost">Sales sq mtrs Cost</label>
            <input type="text" id="pos-sale-cost" class="form-control" name="posSaleCost" placeholder="Enter Sales Cost" tabindex="-1" required readonly />
          </div>           

          <div class="span-full form-subheading">
            <h1>Pricing & Order Terms</h1>
          </div>

          <div class="span-dual">
            <label for="pos-min-qty">Minimum Order QTY</label>
            <input type="text" id="pos-min-qty" class="form-control" name="posMinQty" placeholder="Enter minimum qty" required />
          </div>
          <div class="span-dual">
            <label for="pos-odr-qty">Order QTY</label>
            <input type="text" id="pos-odr-qty" class="form-control" name="posOdrQty" placeholder="Enter order qty" required />
          </div>
          <div class="span-dual">
            <label for="pos-odr-freq">Repeat Order Freq</label>
            <input type="text" id="pos-odr-freq" class="form-control" name="posOdrFreq" placeholder="Enter repeat order frequency" required />
          </div>
          <div class="span-dual">
            <label for="pos-credit-term">CR</label>
            <input type="text" id="pos-credit-term" class="form-control" name="posCreditTerm" placeholder="Enter credit term" required />
          </div>

          <input type="hidden" name="posRollId" id="resolved-pos-roll-id">
          <input type="hidden" name="userId" id="user-id">

          <div class="btn-grp span-full">
            <button type="submit">Save POS Roll</button>
          </div>          
        </form>
      </div>

<!-- ===== RATE CALCULATION & JS ===== -->
<script>
document.addEventListener("DOMContentLoaded", () => {
  /* ================= ELEMENTS ================= */
  const submitBtn = document.querySelector("button[type='submit']");

  const clientSelect = document.getElementById("client-name");
  const userSelect = document.getElementById("client-user-name");

  const userIdInput = document.getElementById("user-id");
  const userContactInput = document.getElementById("user-contact");
  const locationInput = document.getElementById("client-location");
  const posMtrsInput = document.getElementById("pos-mtrs");
  const posMtrsDelInput = document.getElementById("pos-mtrs-del");

  const posRollIdInput = document.getElementById("resolved-pos-roll-id");
  const posRollIdDisplay = document.getElementById("pos-roll-id");

  const posRollFields = [
    "pos-paper-code",
    "pos-paper-type",
    "pos-color",
    "pos-gsm",
    "pos-width",
    "pos-mtrs",
    "pos-core-id",
  ];

  const fieldToApiKey = {
    "pos-paper-code": "paperCodes",
    "pos-paper-type": "paperTypes",
    "pos-color": "colors",
    "pos-gsm": "gsms",
    "pos-width": "widths",
    "pos-mtrs": "mtrsList",
    "pos-core-id": "coreIds",
  };

  const fieldToParam = {
    "pos-paper-code": "posPaperCode",
    "pos-paper-type": "posPaperType",
    "pos-color": "posColor",
    "pos-gsm": "posGsm",
    "pos-width": "posWidth",
    "pos-mtrs": "posMtrs",
    "pos-core-id": "posCoreId",
  };

  submitBtn.disabled = true;

  /* ================= CHOICES INIT ================= */
  const clientChoices = new Choices(clientSelect, {
    searchEnabled: true,
    shouldSort: false,
    itemSelectText: "",
  });

  const userChoices = new Choices(userSelect, {
    searchEnabled: true,
    shouldSort: false,
    itemSelectText: "",
  });

  const specChoices = {};
  posRollFields.forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      specChoices[id] = new Choices(el, {
        searchEnabled: true,
        shouldSort: false,
        itemSelectText: "",
      });
    }
  });

  /* ================= HELPERS ================= */
  function resetUserFields() {
    userIdInput.value = "";
    userContactInput.value = "";
    locationInput.value = "";
  }

  function hardResetUserSelection() {
    userChoices.removeActiveItems();
    userChoices.clearChoices();
    resetUserFields();
  }

  function resetResolvedPosRoll() {
    posRollIdInput.value = "";
    posRollIdDisplay.value = "";
    submitBtn.disabled = true;
    posRollIdDisplay.classList.remove("pos-roll-id-success", "pos-roll-id-error");
  }

  function syncDeliveredMeters() {
    if (!posMtrsInput || !posMtrsDelInput) return;
    const currentMtrs = posMtrsInput.value;
    posMtrsDelInput.value = currentMtrs || "";
  }

  /* ================= SMART FILTER ================= */
  async function filterSpecs(changedFieldId) {
    const params = new URLSearchParams();
    posRollFields.forEach(id => {
      const el = document.getElementById(id);
      if (el && el.value) {
        params.set(fieldToParam[id], el.value);
      }
    });

    try {
      const res = await fetch(`/fairdesk/form/pos-roll-binding/filter-specs?${params}`);
      const data = await res.json();
      if (!data) return;

      const autoSelected = [];

      posRollFields.forEach(id => {
        if (id === changedFieldId) return; // skip the field that triggered the filter
        const choicesInstance = specChoices[id];
        if (!choicesInstance) return;

        const apiKey = fieldToApiKey[id];
        const filteredValues = data[apiKey] || [];
        const currentValue = document.getElementById(id)?.value || "";

        const newChoices = filteredValues.map(v => ({
          value: String(v),
          label: String(v),
          selected: String(v) === currentValue,
        }));

        // Auto-select if exactly one option and nothing currently selected (and not resetting)
        if (changedFieldId !== "reset-all" && filteredValues.length === 1 && !currentValue) {
          newChoices[0].selected = true;
          autoSelected.push(id);
        }

        choicesInstance.clearStore();
        choicesInstance.setChoices(
          [{ value: "", label: "Search", disabled: true, selected: !newChoices.some(c => c.selected) }, ...newChoices],
          "value",
          "label",
          true
        );
      });

      // If any fields were auto-selected, re-run filter to cascade
      if (autoSelected.length > 0) {
        await filterSpecs(autoSelected[0]);
        resolvePosRoll();
      }
    } catch (err) {
      console.error("Filter specs error:", err);
    }
  }

  /* ================= CLIENT → USER ================= */
  clientSelect.addEventListener("change", async () => {
    const clientName = clientSelect.value;
    hardResetUserSelection();

    const res = await fetch(`/fairdesk/form/pos-roll-binding/client/${clientName}`);
    const clientData = await res.json();
    if (!clientData || !clientData.users) return;

    if (clientData.users.length === 1) {
      const u = clientData.users[0];
      userChoices.setChoices(
        [{
          value: u._id,
          label: u.userName,
          selected: true,
          customProperties: { mobile: u.userContact || "", location: u.userLocation || "" }
        }],
        "value",
        "label",
        true
      );
      userIdInput.value = u._id;
      userContactInput.value = u.userContact || "";
      locationInput.value = u.userLocation || "";
      return;
    }

    userChoices.setChoices(
      clientData.users.map(u => ({
        value: u._id,
        label: u.userName,
        customProperties: { mobile: u.userContact || "", location: u.userLocation || "" }
      })),
      "value",
      "label",
      true
    );
    resetUserFields();
  });

  /* ================= USER CHANGE ================= */
  userSelect.addEventListener("change", () => {
    const selectedId = userChoices.getValue(true);
    if (!selectedId) return;

    const choice = userChoices._store.choices.find(c => c.value === selectedId);
    if (!choice) return;

    userIdInput.value = choice.value;
    userContactInput.value = choice.customProperties?.mobile || "";
    locationInput.value = choice.customProperties?.location || "";
  });

  /* ================= POS ROLL RESOLVE ================= */
  async function resolvePosRoll() {
    resetResolvedPosRoll();
    syncDeliveredMeters();

    const values = {};
    for (let id of posRollFields) {
      const el = document.getElementById(id);
      if (!el || !el.value) return;
      values[id] = el.value;
    }

    const params = new URLSearchParams({
      posPaperCode: values["pos-paper-code"],
      posPaperType: values["pos-paper-type"],
      posColor: values["pos-color"],
      posGsm: values["pos-gsm"],
      posWidth: values["pos-width"],
      posMtrs: values["pos-mtrs"],
      posCoreId: values["pos-core-id"],
    });

    const res = await fetch(`/fairdesk/form/pos-roll-binding/resolve-pos-roll?${params}`);

    if (!res.ok) {
      posRollIdDisplay.value = "No matching POS Roll found";
      posRollIdDisplay.classList.add("pos-roll-id-error");
      return;
    }

    const data = await res.json();

    posRollIdInput.value = data.posRollId;
    posRollIdDisplay.value = data.posProductId;
    posRollIdDisplay.classList.add("pos-roll-id-success");
    submitBtn.disabled = false;

    document.getElementById("pos-client-paper-code").value = values["pos-paper-code"];
    document.getElementById("pos-client-gsm").value = values["pos-gsm"];
  }

  /* ================= SPEC CHANGE HANDLER ================= */
  posRollFields.forEach(id => {
    document.getElementById(id)?.addEventListener("change", async () => {
      await filterSpecs(id);
      resolvePosRoll();
    });
  });

  /* ================= RESET SPECS ================= */
  const resetSpecsBtn = document.getElementById("reset-specs-btn");
  if (resetSpecsBtn) {
    resetSpecsBtn.addEventListener("click", async () => {
      // Clear underlying values for pos roll specs & reset their Choices UI
      posRollFields.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = "";
        
        // Also clear the Choices visible selection
        if (specChoices[id]) {
          specChoices[id].setChoiceByValue("");
        }
      });
      
      resetResolvedPosRoll();

      // Clear the overrides if populated
      const clientPaperCode = document.getElementById("pos-client-paper-code");
      if (clientPaperCode) clientPaperCode.value = "";
      const clientGsm = document.getElementById("pos-client-gsm");
      if (clientGsm) clientGsm.value = "";

      // Clear all other text inputs
      const otherInputs = [
        "pos-mtrs-del",
        "pos-rate-per-roll",
        "pos-sale-cost",
        "pos-min-qty",
        "pos-odr-qty",
        "pos-odr-freq",
        "pos-credit-term"
      ];
      otherInputs.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = "";
      });

      // Reset Client and User dropdowns
      if (typeof clientChoices !== "undefined") {
        clientChoices.setChoiceByValue("");
      }
      hardResetUserSelection();
      
      // Fetch fresh, unfiltered options and apply them to all fields
      await filterSpecs("reset-all");
    });
  }

  /* ================= RATE CALC ================= */
  const widthInput = document.getElementById("pos-width");
  const ratePerRollInput = document.getElementById("pos-rate-per-roll");
  const saleCostInput = document.getElementById("pos-sale-cost");

  function calcSaleCost() {
    if (!widthInput.value || !posMtrsInput.value || !ratePerRollInput.value) return;
    const area = (Number(widthInput.value) * Number(posMtrsInput.value)) / 1000;
    if (!area) return;
    saleCostInput.value = (Number(ratePerRollInput.value) / area).toFixed(4);
  }

  widthInput.addEventListener("input", calcSaleCost);
  posMtrsInput.addEventListener("input", () => {
    syncDeliveredMeters();
    calcSaleCost();
  });
  posMtrsInput.addEventListener("change", syncDeliveredMeters);
  posMtrsInput.addEventListener("addItem", syncDeliveredMeters);
  ratePerRollInput.addEventListener("input", calcSaleCost);
});

/* ================= CUSTOM TOAST ================= */
function showClientToast(message, isError = true) {
  const existingToast = document.getElementById("client-toast");
  if (existingToast) existingToast.remove();

  const toast = document.createElement("div");
  toast.id = "client-toast";
  toast.className = `toast-notification ${isError ? 'toast-error' : 'toast-success'}`;
  toast.innerHTML = `
    <span>${message}</span>
    <span class="toast-close" onclick="this.parentElement.remove()">×</span>
  `;

  document.body.appendChild(toast);

  setTimeout(() => {
    if (toast.parentElement) {
       toast.style.animation = "slideOut 0.5s forwards";
       setTimeout(() => toast.remove(), 500);
    }
  }, 5000);
}

/* ================= FORM GUARD ================= */
function validatePosRollBeforeSubmit() {
  const posRollId = document.getElementById("resolved-pos-roll-id").value;
  if (!posRollId) {
    showClientToast("Please select a valid POS Roll specification.", true);
    return false;
  }

  const minQty = Number(document.getElementById("pos-min-qty").value);
  const odrQty = Number(document.getElementById("pos-odr-qty").value);

  if (minQty >= odrQty) {
    showClientToast("Order Quantity must be greater than Minimum Order Quantity", true);
    return false;
  }

  return true;
}
</script>
