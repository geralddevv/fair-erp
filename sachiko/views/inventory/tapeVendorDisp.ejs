<!-- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>

<!-- Tabulator CSS -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />
<link href="https://unpkg.com/tabulator-tables@5.6.2/dist/css/tabulator_modern.min.css" rel="stylesheet">
</head>

<body>
  <div class="contain" style="flex-direction: column; padding: 10px; gap: 10px" >
      <style>
        .header-action-btn {
          background-color: #f0f0f0;
          color: #044a78;
          padding: 2px 14px;
          font-size: 14px;
          font-weight: 500;
          border: none;
          cursor: pointer;
          border-radius: 0.5rem;
          box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
          transition: all 0.2s ease-in-out;
          display: flex;
          align-items: center;
          justify-content: center;
        }

        .header-action-btn:hover {
          background-color: #e4e4e4;
        }
        #master-table {
          width: 100%;
          flex: 1 1 auto;
          min-height: 0;
        }
      </style>
      <div class="indi-head">
        <h1>
          Vendor Tapes
          <% if (typeof vendorUser !== "undefined" && vendorUser && (vendorUser.vendorName || vendorUser.userName)) { %>
            - <%= vendorUser.vendorName || "" %><%= vendorUser.vendorName && vendorUser.userName ? " / " : "" %><%= vendorUser.userName || "" %>
          <% } %>
        </h1>
        <div class="download-btns">
            <button class="header-action-btn" onclick="window.location.href = '/fairdesk/form/vendor-item-binding/tape'">
                <i class="fa-solid fa-plus" style="margin-right: 4px"></i> Bind Tape
            </button>
          <div class="download-selector" id="downloadSelector">
            <button class="download-selector__trigger">
              <span>
                <i class="fa-solid fa-file-arrow-down"></i>
                <span class="download-typo">Download</span>
              </span>
              <i class="fas fa-chevron-down download-selector__trigger-icon"></i>
            </button>
            <div class="download-selector__menu" id="downloads">
              <span class="download-selector__option" id="download-pdf">
                <i class="fas fa-file-pdf download-selector__option-icon"></i>
                <span>PDF</span>
              </span>
              <span class="download-selector__option" id="download-xlsx">
                <i class="fas fa-file-excel download-selector__option-icon"></i>
                <span>Excel</span>
              </span>
            </div>
          </div>
      </div>
    </div>

  <div class="table-spinner"><div class="spinner-circle"></div></div>
  <div id="master-table" class="tabulator tabulator-modern"></div>
</div>

<form id="deleteBindingForm" method="POST" style="display:none;">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
</form>
<div class="logout-modal" id="deleteBindingModal" aria-hidden="true">
  <div class="logout-dialog" role="dialog" aria-modal="true" aria-labelledby="deleteBindingTitle">
    <h2 class="logout-title" id="deleteBindingTitle">Remove binding?</h2>
    <p class="logout-text">This will permanently remove this vendor Tape binding.</p>
    <div class="logout-actions">
      <button class="logout-btn" type="button" id="deleteBindingCancel">Cancel</button>
      <button class="logout-btn primary" type="button" id="deleteBindingConfirm">Remove</button>
    </div>
  </div>
</div>

  <!-- Tabulator JS -->
  <script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>

  <script id="table-data" type="application/json"><%- safeJson(jsonData || []) %></script>
  <script>
    const tableData = JSON.parse(document.getElementById('table-data').textContent);

    let bindingToDelete = "";
    const deleteForm = document.getElementById("deleteBindingForm");
    const deleteModal = document.getElementById("deleteBindingModal");
    const deleteConfirmBtn = document.getElementById("deleteBindingConfirm");
    const deleteCancelBtn = document.getElementById("deleteBindingCancel");

    window.promptDeleteBinding = function (bindingId) {
      bindingToDelete = String(bindingId || "");
      deleteModal.style.display = "flex";
      deleteModal.classList.add("show");
      deleteModal.setAttribute("aria-hidden", "false");
    };

    function closeDeleteModal() {
      deleteModal.classList.remove("show");
      deleteModal.setAttribute("aria-hidden", "true");
      deleteModal.style.display = "none";
      bindingToDelete = "";
    }

    deleteCancelBtn.addEventListener("click", closeDeleteModal);
    deleteModal.addEventListener("click", (e) => {
      if (e.target === deleteModal) closeDeleteModal();
    });
    deleteConfirmBtn.addEventListener("click", () => {
      if (!bindingToDelete) return closeDeleteModal();
      deleteForm.action = `/fairdesk/vendor-item/delete/tape/${bindingToDelete}`;
      deleteForm.submit();
    });

    const table = new Tabulator("#master-table", {
      data: tableData,
      height: "100%",
      // layout: "fitColumns",
      responsiveLayout: false,
      movableColumns: true,
      placeholder: "No data to display",
      columns: [
        {
          title: "Action",
          hozAlign: "center",
          headerHozAlign: "center",
          width: 132,
          minWidth: 132,
          widthGrow: 0,
          widthShrink: 0,
          formatter: function (cell) {
            const row = cell.getRow().getData();
            if (!row._id) return `<span style="color:#999">N/A</span>`;
            return `
              <div style="display:flex;align-items:center;justify-content:center;gap:6px;padding:0 1px;">
                <button 
                  onclick="window.location.href='/fairdesk/vendor-item/compare/tape/${row._id}'"
                  style="padding:2px 8px;min-width:30px;background:#044A78;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;"
                  title="View Binding">
                  <i class="fa-solid fa-eye"></i>
                </button>
                <button
                  onclick="window.location.href='/fairdesk/vendor-item/edit/tape/${row._id}?returnTo=${encodeURIComponent(window.location.pathname + window.location.search)}'"
                  style="padding:2px 8px;min-width:30px;background:#e67e22;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;"
                  title="Edit Binding">
                  <i class="fa-solid fa-pen-to-square"></i>
                </button>
                <button 
                  onclick="promptDeleteBinding('${row._id}')"
                  style="padding:2px 8px;min-width:30px;background:#d9534f;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;"
                  title="Remove Binding">
                  <i class="fa-solid fa-trash"></i>
                </button>
              </div>
            `;
          }
        },
        {
          title: "Status",
          field: "status",
          hozAlign: "center",
          headerFilter: "input",
          headerFilterPlaceholder: "Filter",
          formatter: function (cell) {
            const val = cell.getValue() || "ACTIVE";
            const isActive = val === "ACTIVE";
            const bg = isActive ? "#28a745" : "#dc3545";
            return `<span style="background:${bg};color:#fff;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;">${val}</span>`;
          }
        },
        {
          title: "Stock",
          field: "stock",
          hozAlign: "center",
          formatter: (cell) => {
            const stock = cell.getValue() ?? "-";
            return `<span style="font-weight:600">${stock}</span>`;
          }
        },        
        { title: "Item ID", field: "displayValue", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Vendor", field: "vendorName", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Coordinator", field: "userName", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Contact", field: "userContact", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Vendor Paper Code", field: "vendorTapePaperCode", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Vendor Paper Type", field: "vendorTapePaperType", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Vendor GSM", field: "vendorTapeGsm", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "MSQ", field: "tapeMinQty" },
      ]
    });

    const selector = document.getElementById("downloadSelector");
    const trigger = selector.querySelector(".download-selector__trigger");
    
    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      selector.classList.toggle("download-selector--active");
    });
  
    document.addEventListener("click", () => {
      selector.classList.remove("download-selector--active");
    });
  
    document.getElementById("download-pdf").addEventListener("click", () => {
      table.download("pdf", "vendor_tape.pdf", {
        orientation: "landscape",
        title: "Vendor Tape Data",
      });
      selector.classList.remove("download-selector--active");
    });
  
    document.getElementById("download-xlsx").addEventListener("click", () => {
      table.download("xlsx", "vendor_tape.xlsx", {
        sheetName: "Vendor Tape",
      });
      selector.classList.remove("download-selector--active");
    });
  </script>
</body>
