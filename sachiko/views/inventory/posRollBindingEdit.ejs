<% layout('/layout/boilerplate') -%>

<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
  <form
    class="needs-validation"
    action="/fairdesk/pos-roll-binding/edit/<%= binding._id %>"
    method="post"
    autocomplete="off"
    novalidate
  >
    <input type="hidden" name="returnTo" value="<%= returnTo || '' %>" />
    <div class="span-full form-subheading gap">
      <h1>Edit POS Roll Binding</h1>
    </div>

    <!-- ================= READ-ONLY INFO ================= -->

    <div class="span-six">
      <label>POS Roll ID</label>
      <input
        type="text"
        class="form-control input-tag"
        value="<%= binding.posRollId?.posProductId || 'N/A' %>"
        readonly
      />
    </div>

    <div class="span-six">
      <label>Paper Code</label>
      <input type="text" class="form-control input-tag" value="<%= binding.posRollId?.posPaperCode || '' %>" readonly />
    </div>

    <div class="span-seven">
      <label>User Name</label>
      <input type="text" class="form-control input-tag" value="<%= binding.userId?.userName || '' %>" readonly />
    </div>

    <div class="span-seven">
      <label>Client Name</label>
      <input type="text" class="form-control input-tag" value="<%= binding.userId?.clientName || '' %>" readonly />
    </div>

    <!-- ================= POS ROLL MASTER SPECS (READ-ONLY) ================= -->

    <div class="span-six">
      <label>Paper Type</label>
      <input type="text" class="form-control input-tag" value="<%= binding.posRollId?.posPaperType || '' %>" readonly />
    </div>

    <div class="span-seven">
      <label>Color</label>
      <input type="text" class="form-control input-tag" value="<%= binding.posRollId?.posColor || '' %>" readonly />
    </div>

    <div class="span-six">
      <label>GSM</label>
      <input type="text" class="form-control input-tag" value="<%= binding.posRollId?.posGsm || '' %>" readonly />
    </div>

    <div class="span-six">
      <label>Width</label>
      <input
        type="text"
        class="form-control input-tag"
        id="pos-width"
        value="<%= binding.posRollId?.posWidth || '' %>"
        readonly
      />
    </div>

    <div class="span-six">
      <label>MTRS</label>
      <input
        type="text"
        class="form-control input-tag"
        id="pos-mtrs"
        value="<%= binding.posRollId?.posMtrs || '' %>"
        readonly
      />
    </div>

    <div class="span-seven">
      <label>Core ID</label>
      <input type="text" class="form-control input-tag" value="<%= binding.posRollId?.posCoreId || '' %>" readonly />
    </div>

    <!-- ================= CLIENT SPECIFICATIONS ================= -->

    <div class="span-full form-subheading">
      <h1>Client Specifications</h1>
    </div>

    <div class="span-seven">
      <label>Client Paper Code</label>
      <input
        type="text"
        name="posClientPaperCode"
        class="form-control"
        value="<%= binding.posClientPaperCode %>"
        required
      />
    </div>

    <div class="span-seven">
      <label>Client GSM</label>
      <input type="text" name="clientPosGsm" class="form-control" value="<%= binding.clientPosGsm %>" required />
    </div>

    <div class="span-six">
      <label>MTRS Delivered</label>
      <input type="text" name="posMtrsDel" class="form-control" value="<%= binding.posMtrsDel %>" required />
    </div>

    <div class="span-six">
      <label>Rate Per Roll</label>
      <input
        type="text"
        name="posRatePerRoll"
        id="pos-rate-per-roll"
        class="form-control"
        value="<%= binding.posRatePerRoll %>"
        required
      />
    </div>

    <div class="span-six">
      <label>Sales sq mtrs Cost</label>
      <input
        type="text"
        name="posSaleCost"
        id="pos-sale-cost"
        class="form-control"
        value="<%= binding.posSaleCost %>"
        tabindex="-1"
        required
        readonly
      />
    </div>

    <!-- ================= PRICING & ORDER TERMS ================= -->

    <div class="span-full form-subheading">
      <h1>Pricing & Order Terms</h1>
    </div>

    <div class="span-seven">
      <label>Minimum Order QTY</label>
      <input type="text" name="posMinQty" class="form-control" value="<%= binding.posMinQty %>" required />
    </div>

    <div class="span-six">
      <label>Order QTY</label>
      <input type="text" name="posOdrQty" class="form-control" value="<%= binding.posOdrQty %>" required />
    </div>

    <div class="span-seven">
      <label>Repeat Order Freq</label>
      <input type="text" name="posOdrFreq" class="form-control" value="<%= binding.posOdrFreq || '' %>" required />
    </div>

    <div class="span-six">
      <label>CR</label>
      <input
        type="text"
        name="posCreditTerm"
        class="form-control"
        value="<%= binding.posCreditTerm || '' %>"
        required
      />
    </div>

    <div class="span-six">
      <label>Status</label>
      <select name="status" class="form-control select-tag" required>
        <option value="ACTIVE" <%= binding.status === "ACTIVE" ? "selected" : "" %>>ACTIVE</option>
        <option value="INACTIVE" <%= binding.status === "INACTIVE" ? "selected" : "" %>>INACTIVE</option>
      </select>
    </div>    

    <!-- ================= BUTTONS ================= -->

    <div class="span-full btn-grp" style="flex-direction: row-reverse">
      <button class="submit-btn" type="submit">Update POS Roll Binding</button>
      <button type="button" id="cancelBtn">Cancel</button>
    </div>
  </form>
</div>

<script>
  document.getElementById("cancelBtn").addEventListener("click", () => {
    window.history.back();
  });

  const widthVal = Number(document.getElementById("pos-width").value) || 0;
  const mtrsVal = Number(document.getElementById("pos-mtrs").value) || 0;
  const rateInput = document.getElementById("pos-rate-per-roll");
  const costInput = document.getElementById("pos-sale-cost");

  function calcSaleCost() {
    const area = (widthVal * mtrsVal) / 1000;
    if (!area || !rateInput.value) return;
    costInput.value = (Number(rateInput.value) / area).toFixed(4);
  }

  rateInput.addEventListener("input", calcSaleCost);
</script>
