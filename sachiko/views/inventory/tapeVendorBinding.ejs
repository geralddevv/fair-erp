<% layout('/layout/boilerplate') %>

<%
  const cfg = pageConfig || {};
  const specFields = cfg.specFields || [];
  const overrideFields = cfg.overrideFields || [];
%>

<style>
  .item-id-success {
    border: 2px solid #28a745 !important;
    background-color: #f3fff6;
    color: #155724;
    font-weight: 600;
  }

  .item-id-error {
    border: 2px solid #dc3545 !important;
    background-color: #fff5f5;
    color: #721c24;
    font-weight: 600;
  }
</style>

<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
  <form id="vendor-item-form" action="/fairdesk/form/vendor-item-binding/<%= cfg.key %>" method="post" class="needs-validation" autocomplete="off" novalidate>
    <div class="span-full form-heading">
      <h1>Vendor Tape</h1>
    </div>

    <div class="span-full form-subheading">
      <h1>FS Info</h1>
    </div>

    <div class="span-six">
      <label for="resolved-item-display">Item ID</label>
      <input type="text" id="resolved-item-display" class="form-control" placeholder="Will appear here" readonly required />
    </div>    

    <div class="span-seven">
      <label for="vendor-name">Vendor Name</label>
      <select name="vendorName" id="vendor-name" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% (vendors || []).forEach((vendor) => { %>
          <option value="<%= vendor %>"><%= vendor %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-seven">
      <label for="vendor-user-name">Vendor User</label>
      <select name="vendorUserId" id="vendor-user-name" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
      </select>
    </div>

    <div class="span-six">
      <label for="vendor-user-contact">Contact</label>
      <input type="text" id="vendor-user-contact" class="form-control" name="userContact" placeholder="Will appear here" readonly required />
    </div>

    <div class="span-six">
      <label for="vendor-user-location">Location</label>
      <input type="text" id="vendor-user-location" class="form-control" name="userLocation" placeholder="Will appear here" readonly required />
    </div>

    <div class="span-full form-subheading" style="display: flex; justify-content: space-between; align-items: center;">
      <h1>Tape Specifications</h1>
      <button type="button" id="reset-specs-btn" style="padding: 4px 12px; border-radius: 4px; background-color: #dc3545; color: white; border: none; cursor: pointer; font-size: 14px;">
        Reset
      </button>
    </div>

    <div class="span-five">
      <label for="tape-paper-code">Paper Code</label>
      <select name="tapePaperCode" id="tape-paper-code" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% (specOptions.tapePaperCode || []).forEach((opt) => { %>
          <option value="<%= opt %>"><%= opt %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-five">
      <label for="tape-paper-type">Paper Type</label>
      <select name="tapePaperType" id="tape-paper-type" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% (specOptions.tapePaperType || []).forEach((opt) => { %>
          <option value="<%= opt %>"><%= opt %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-four">
      <label for="tape-gsm">GSM</label>
      <select name="tapeGsm" id="tape-gsm" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% (specOptions.tapeGsm || []).forEach((opt) => { %>
          <option value="<%= opt %>"><%= opt %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-four">
      <label for="tape-width">Width</label>
      <select name="tapeWidth" id="tape-width" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% (specOptions.tapeWidth || []).forEach((opt) => { %>
          <option value="<%= opt %>"><%= opt %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-four">
      <label for="tape-mtrs">Meters</label>
      <select name="tapeMtrs" id="tape-mtrs" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% (specOptions.tapeMtrs || []).forEach((opt) => { %>
          <option value="<%= opt %>"><%= opt %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-five">
      <label for="tape-core-id">Core ID</label>
      <select name="tapeCoreId" id="tape-core-id" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% (specOptions.tapeCoreId || []).forEach((opt) => { %>
          <option value="<%= opt %>"><%= opt %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-five">
      <label for="tape-finish">Finish</label>
      <select name="tapeFinish" id="tape-finish" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% (specOptions.tapeFinish || []).forEach((opt) => { %>
          <option value="<%= opt %>"><%= opt %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-full form-subheading">
      <h1>Vendor Overrides</h1>
    </div>

    <div class="span-seven">
      <label for="vendor-tape-paper-code">Vendor Paper Code</label>
      <input type="text" id="vendor-tape-paper-code" class="form-control" name="vendorTapePaperCode" placeholder="Enter Vendor Paper Code" required />
    </div>

    <div class="span-seven">
      <label for="vendor-tape-gsm">Vendor GSM</label>
      <input type="number" id="vendor-tape-gsm" class="form-control" name="vendorTapeGsm" placeholder="Enter Vendor GSM" required />
    </div>

    <div class="span-six">
      <label for="vendor-tape-paper-type">Vendor Paper Type</label>
      <input type="text" id="vendor-tape-paper-type" class="form-control" name="vendorTapePaperType" placeholder="Enter Vendor Paper Type" required />
    </div>

    <div class="span-six">
      <label for="tape-rate-per-roll">Rate</label>
      <input type="number" id="tape-rate-per-roll" class="form-control" name="tapeRatePerRoll" placeholder="Enter rate" step="0.01" min="0" />
    </div>    

    <div class="span-six">
      <label for="tape-min-qty">MSQ</label>
      <input type="number" id="tape-min-qty" class="form-control" name="tapeMinQty" placeholder="Enter MSQ" min="0" required />
    </div>

    <input type="hidden" name="<%= cfg.bindingField %>" id="resolved-item-id" />

    <div class="btn-grp span-full">
      <button type="submit" id="vendor-item-submit">Save <%= cfg.heading %></button>
    </div>
  </form>
</div>

<script>
document.addEventListener("DOMContentLoaded", async () => {
  const pageConfig = <%- safeJson(cfg) %>;
  const prefillData = <%- safeJson(prefillData) %>;

  const form = document.getElementById("vendor-item-form");
  const submitBtn = document.getElementById("vendor-item-submit");
  const vendorSelect = document.getElementById("vendor-name");
  const userSelect = document.getElementById("vendor-user-name");
  const contactInput = document.getElementById("vendor-user-contact");
  const locationInput = document.getElementById("vendor-user-location");
  const itemIdInput = document.getElementById("resolved-item-id");
  const itemDisplayInput = document.getElementById("resolved-item-display");

  const tapeFields = [
    "tape-paper-code",
    "tape-paper-type",
    "tape-gsm",
    "tape-width",
    "tape-mtrs",
    "tape-core-id",
    "tape-finish",
  ];

  const fieldToApiKey = {
    "tape-paper-code": "tapePaperCode",
    "tape-paper-type": "tapePaperType",
    "tape-gsm": "tapeGsm",
    "tape-width": "tapeWidth",
    "tape-mtrs": "tapeMtrs",
    "tape-core-id": "tapeCoreId",
    "tape-finish": "tapeFinish",
  };

  const fieldToParam = {
    "tape-paper-code": "tapePaperCode",
    "tape-paper-type": "tapePaperType",
    "tape-gsm": "tapeGsm",
    "tape-width": "tapeWidth",
    "tape-mtrs": "tapeMtrs",
    "tape-core-id": "tapeCoreId",
    "tape-finish": "tapeFinish",
  };

  const vendorChoices = new Choices(vendorSelect, { searchEnabled: true, shouldSort: false, itemSelectText: "" });
  const userChoices = new Choices(userSelect, { searchEnabled: true, shouldSort: false, itemSelectText: "" });
  
  const specChoices = {};
  tapeFields.forEach((id) => {
    const el = document.getElementById(id);
    if (el) {
      specChoices[id] = new Choices(el, { searchEnabled: true, shouldSort: false, itemSelectText: "" });
    }
  });

  const vendorTapePaperCodeEl = document.getElementById("vendor-tape-paper-code");
  const vendorTapeGsmEl = document.getElementById("vendor-tape-gsm");
  const vendorTapePaperTypeEl = document.getElementById("vendor-tape-paper-type");
  const tapeMinQtyEl = document.getElementById("tape-min-qty");

  let smartFilterBusy = false;

  function resetUserFields() {
    contactInput.value = "";
    locationInput.value = "";
  }

  function resetUserChoices() {
    userChoices.removeActiveItems();
    userChoices.clearChoices();
    userChoices.setChoices([{ value: "", label: "Search", disabled: true, selected: true }], "value", "label", true);
    resetUserFields();
  }

  function resetResolvedItem() {
    itemIdInput.value = "";
    itemDisplayInput.value = "";
    itemDisplayInput.classList.remove("item-id-success", "item-id-error");
    submitBtn.disabled = true;
  }

  function resetSelect(instance) {
    if (!instance) return;
    instance.clearStore();
    instance.setChoices([{ value: "", label: "Search", disabled: true, selected: true }], "value", "label", true);
  }

  function prefillVendorOverrides(data) {
    if (vendorTapePaperCodeEl && !vendorTapePaperCodeEl.value) {
      vendorTapePaperCodeEl.value = data.tapePaperCode || "";
    }
    if (vendorTapeGsmEl && !vendorTapeGsmEl.value) {
      vendorTapeGsmEl.value = data.tapeGsm || "";
    }
    if (vendorTapePaperTypeEl && !vendorTapePaperTypeEl.value) {
      vendorTapePaperTypeEl.value = data.tapePaperType || "";
    }
    if (tapeMinQtyEl && !tapeMinQtyEl.value && data[pageConfig.minQtyField]) {
      tapeMinQtyEl.value = data[pageConfig.minQtyField];
    }
  }

  async function populateVendorUsers(vendorName) {
    resetUserChoices();
    if (!vendorName) return;

    try {
      const response = await fetch(`/fairdesk/form/vendor-item-binding/${pageConfig.key}/vendor/${encodeURIComponent(vendorName)}`);
      const vendorData = await response.json();
      const users = Array.isArray(vendorData?.users) ? vendorData.users : [];
      if (!users.length) return;

      userChoices.setChoices(
        users.map((user, index) => ({
          value: user._id,
          label: user.userName || "",
          selected: index === 0,
          customProperties: {
            contact: user.userContact || "",
            location: user.userLocation || "",
          },
        })),
        "value",
        "label",
        true,
      );

      contactInput.value = users[0].userContact || "";
      locationInput.value = users[0].userLocation || "";
    } catch (err) {
      console.error("Vendor users fetch failed:", err);
      resetUserChoices();
    }
  }

  async function filterSpecs(changedFieldId) {
    const params = new URLSearchParams();
    tapeFields.forEach((id) => {
      const el = document.getElementById(id);
      if (el && el.value) {
        params.set(fieldToParam[id], el.value);
      }
    });

    const res = await fetch(`/fairdesk/form/vendor-item-binding/${pageConfig.key}/filter-specs?${params}`);
    const data = await res.json();
    if (!data) return;

    const autoSelected = [];

    tapeFields.forEach((id) => {
      if (id === changedFieldId) return;
      const apiKey = fieldToApiKey[id];
      const filteredValues = data[apiKey] || [];
      const currentValue = document.getElementById(id)?.value || "";
      const filteredValueSet = new Set(filteredValues.map((v) => String(v)));
      const choicesInstance = specChoices[id];

      if (choicesInstance) {
        const newChoices = filteredValues.map((v) => ({
          value: String(v),
          label: String(v),
          selected: String(v) === currentValue,
        }));

        if (changedFieldId !== "reset-all" && filteredValues.length === 1 && !currentValue) {
          newChoices[0].selected = true;
          autoSelected.push(id);
          const autoValue = String(filteredValues[0]);
          if (id === "tape-paper-code" && vendorTapePaperCodeEl) vendorTapePaperCodeEl.value = autoValue;
          if (id === "tape-paper-type" && vendorTapePaperTypeEl) vendorTapePaperTypeEl.value = autoValue;
          if (id === "tape-gsm" && vendorTapeGsmEl) vendorTapeGsmEl.value = autoValue;
        }

        choicesInstance.clearStore();
        choicesInstance.setChoices(
          [{ value: "", label: "Search", disabled: true, selected: !newChoices.some((c) => c.selected) }, ...newChoices],
          "value",
          "label",
          true,
        );

        if (currentValue && filteredValueSet.has(String(currentValue))) {
          choicesInstance.setChoiceByValue(String(currentValue));
        } else if (changedFieldId !== "reset-all" && filteredValues.length === 1 && !currentValue) {
          choicesInstance.setChoiceByValue(String(filteredValues[0]));
        } else if (!filteredValues.length) {
          const el = document.getElementById(id);
          if (el) el.value = "";
        }
      }
    });

    if (autoSelected.length > 0) {
      await filterSpecs(autoSelected[0]);
    }
  }

  async function handleSmartFilterChange(changedFieldId) {
    if (smartFilterBusy) return;
    smartFilterBusy = true;
    try {
      await filterSpecs(changedFieldId);
      await resolveItem();
    } finally {
      smartFilterBusy = false;
    }
  }

  async function resolveItem() {
    resetResolvedItem();
    const values = {};
    for (const id of tapeFields) {
      const el = document.getElementById(id);
      if (!el || !el.value) return;
      values[id] = el.value;
    }

    const params = new URLSearchParams();
    tapeFields.forEach(id => params.set(fieldToParam[id], values[id]));

    const res = await fetch(`/fairdesk/form/vendor-item-binding/${pageConfig.key}/resolve?${params}`);
    if (!res.ok) {
      itemDisplayInput.value = "No matching item found";
      itemDisplayInput.classList.add("item-id-error");
      return;
    }

    const data = await res.json();
    itemIdInput.value = data.itemId;
    itemDisplayInput.value = data.displayValue;
    itemDisplayInput.classList.add("item-id-success");
    submitBtn.disabled = false;

    prefillVendorOverrides(data);
  }

  vendorSelect.addEventListener("change", async () => {
    try {
      await populateVendorUsers(vendorSelect.value);
    } catch (err) {
      console.error("Vendor fetch failed:", err);
      resetUserChoices();
    }
  });

  userSelect.addEventListener("change", () => {
    const selectedId = userChoices.getValue(true);
    if (!selectedId) return resetUserFields();

    const selectedUser = userChoices._store.choices.find((choice) => choice.value === selectedId);
    contactInput.value = selectedUser?.customProperties?.contact || "";
    locationInput.value = selectedUser?.customProperties?.location || "";
  });

  tapeFields.forEach((id) => {
    const field = document.getElementById(id);
    if (!field) return;

    const syncToOverride = (val) => {
      const v = val || "";
      if (id === "tape-paper-code" && vendorTapePaperCodeEl) vendorTapePaperCodeEl.value = v;
      if (id === "tape-paper-type" && vendorTapePaperTypeEl) vendorTapePaperTypeEl.value = v;
      if (id === "tape-gsm" && vendorTapeGsmEl) vendorTapeGsmEl.value = v;
    };

    field.addEventListener("change", () => {
      syncToOverride(field.value);
      handleSmartFilterChange(id);
    });
    field.addEventListener("addItem", (e) => {
      syncToOverride(e.detail.value);
      handleSmartFilterChange(id);
    });
  });

  if (prefillData) {
    tapeFields.forEach(id => {
      const apiKey = fieldToApiKey[id];
      if (prefillData[apiKey] !== undefined) {
        specChoices[id].setChoiceByValue(String(prefillData[apiKey]));
      }
    });
    await resolveItem();
  }



  const resetSpecsBtn = document.getElementById("reset-specs-btn");
  if (resetSpecsBtn) {
    resetSpecsBtn.addEventListener("click", async () => {
      tapeFields.forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.value = "";
        if (specChoices[id]) {
          specChoices[id].setChoiceByValue("");
        }
      });
      resetResolvedItem();
      vendorTapePaperCodeEl.value = "";
      vendorTapeGsmEl.value = "";
      if (vendorTapePaperTypeEl) vendorTapePaperTypeEl.value = "";
      tapeMinQtyEl.value = "";

      vendorChoices.setChoiceByValue("");
      resetUserChoices();
      await filterSpecs("reset-all");
    });
  }


  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    if (!itemIdInput.value) {
      showVendorItemToast("Please select a valid item specification.", true);
      return;
    }



    submitBtn.disabled = true;
    try {
      const response = await fetch(form.action, { method: "POST", body: new FormData(form) });
      const data = await response.json();
      if (!response.ok || !data?.success) {
        showVendorItemToast(data?.message || "Failed to save vendor binding", true);
        submitBtn.disabled = false;
        return;
      }

      window.location.href = data.redirect || pageConfig.redirectTo;
    } catch (err) {
      console.error(err);
      showVendorItemToast("Failed to save vendor binding", true);
      submitBtn.disabled = false;
    }
  });

  submitBtn.disabled = true;
});

function showVendorItemToast(message, isError = true) {
  const existingToast = document.getElementById("vendor-item-toast");
  if (existingToast) existingToast.remove();

  const toast = document.createElement("div");
  toast.id = "vendor-item-toast";
  toast.className = `toast-notification ${isError ? "toast-error" : "toast-success"}`;
  toast.innerHTML = `
    <span>${message}</span>
    <span class="toast-close" onclick="this.parentElement.remove()">Ã—</span>
  `;

  document.body.appendChild(toast);
  setTimeout(() => {
    if (toast.parentElement) {
      toast.style.animation = "slideOut 0.5s forwards";
      setTimeout(() => toast.remove(), 500);
    }
  }, 5000);
}
</script>
