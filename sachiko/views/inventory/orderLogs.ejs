<% layout('/layout/boilerplate') -%>

<!-- Tabulator CSS -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />
<link href="https://unpkg.com/tabulator-tables@5.6.2/dist/css/tabulator_modern.min.css" rel="stylesheet" />

<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
  <div class="indi-head">
    <h1>Order Action Logs</h1>
    <div class="download-btns" style="display: flex; gap: 10px; align-items: center">
      <a
        href="/fairdesk/sales/pending"
        style="
          padding: 6px 14px;
          background: #044a78;
          color: white;
          border-radius: 6px;
          text-decoration: none;
          font-size: 14px;
          font-weight: 500;
          display: inline-flex;
          align-items: center;
          gap: 6px;
          transition: opacity 0.2s;
        "
        onmouseover="this.style.opacity = '0.85'"
        onmouseout="this.style.opacity = '1'"
      >
        <i class="fa-solid fa-arrow-left"></i>
        <span>Back to Pending</span>
      </a>
      <div class="download-selector" id="downloadSelector">
        <button class="download-selector__trigger">
          <span>
            <i class="fa-solid fa-file-arrow-down"></i>
            <span class="download-typo">Download</span>
          </span>
          <i class="fas fa-chevron-down download-selector__trigger-icon"></i>
        </button>
        <div class="download-selector__menu" id="downloads">
          <span class="download-selector__option" id="download-pdf">
            <i class="fas fa-file-pdf download-selector__option-icon"></i>
            <span>PDF</span>
          </span>
          <span class="download-selector__option" id="download-xlsx">
            <i class="fas fa-file-excel download-selector__option-icon"></i>
            <span>Excel</span>
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="table-spinner"><div class="spinner-circle"></div></div>
  <div id="master-table" class="tabulator tabulator-modern"></div>
</div>

<!-- Tabulator JS -->
<script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<script>
  const rawLogsData = <%- safeJson(logs) %>;

  const logsData = rawLogsData.map((log) => {
    const order = log.orderId || {};
    const item = order.tapeId || {};
    const action = log.action || "";
    let actionLabel = action || "-";
    if (action === "DELIVERED" || action === "CONFIRMED") actionLabel = "Delivered";
    else if (action === "CANCELLED") actionLabel = "Cancelled";
    else if (action === "CREATED") actionLabel = "Created";

    let itemTypeLabel = "Tape";
    if (order.onModel === "PosRoll") itemTypeLabel = "POS Roll";
    else if (order.onModel === "Tafeta") itemTypeLabel = "Tafeta";
    else if (order.onModel === "Ttr") itemTypeLabel = "TTR";
    else if (order.onModel === "Label") itemTypeLabel = "Label";

    let itemName = "";
    if (order.onModel === "Tape" || !order.onModel) {
      if (item.tapePaperCode) itemName = `${item.tapePaperCode} ${item.tapeGsm ?? ""}gsm`.trim();
      else if (item.tapeProductId) itemName = String(item.tapeProductId);
    } else if (order.onModel === "PosRoll") {
      if (item.posPaperCode) itemName = `${item.posPaperCode} ${item.posGsm ?? ""}gsm`.trim();
      else if (item.posProductId) itemName = String(item.posProductId);
    } else if (order.onModel === "Tafeta") {
      if (item.tafetaMaterialCode) itemName = `${item.tafetaMaterialCode} ${item.tafetaGsm ?? ""}gsm`.trim();
      else if (item.tafetaProductId) itemName = String(item.tafetaProductId);
    } else if (order.onModel === "Ttr") {
      if (item.ttrType || item.ttrWidth || item.ttrMtrs) {
        itemName = `${item.ttrType || ""} ${item.ttrWidth || ""}mm x ${item.ttrMtrs || ""}m`.replace(/\s+/g, " ").trim();
      } else if (item.ttrProductId) {
        itemName = String(item.ttrProductId);
      }
    } else if (order.onModel === "Label") {
      if (item.labelWidth || item.labelHeight) itemName = `${item.labelWidth || ""}x${item.labelHeight || ""}`;
    }
    if (!itemName) itemName = order.onModel ? `${order.onModel} Item` : "N/A";

    const performedAtDate = log.performedAt ? new Date(log.performedAt) : null;
    const performedAtText = performedAtDate && !Number.isNaN(performedAtDate.getTime())
      ? performedAtDate.toLocaleDateString("en-IN") + " " + performedAtDate.toLocaleTimeString("en-IN", { hour: "2-digit", minute: "2-digit" })
      : "-";

    return {
      ...log,
      performedAtText,
      actionLabel,
      clientName: order.userId?.clientName || "N/A",
      itemTypeLabel,
      itemName,
      invoiceDisplay: log.invoiceNumber || "-",
      cancelReasonDisplay: log.cancelReason || "-",
    };
  });

  const table = new Tabulator("#master-table", {
    data: logsData,
    // layout: "fitColumns",
    responsiveLayout: false,
    movableColumns: true,
    placeholder: "No order logs found",
    columns: [
      {
        title: "Date",
        field: "performedAtText",
        width: 160,
        headerFilter: "input",
        headerFilterPlaceholder: "Search date",
      },
      {
        title: "Action",
        field: "actionLabel",
        width: 120,
        hozAlign: "center",
        headerFilter: "input",
        headerFilterPlaceholder: "Search action",
        formatter: (cell) => {
          const action = cell.getRow().getData().action;
          let bg = "#6b7280";
          let label = cell.getValue();
          if (action === "DELIVERED" || action === "CONFIRMED") { bg = "#10b981"; label = "Delivered"; }
          else if (action === "CANCELLED") { bg = "#ef4444"; label = "Cancelled"; }
          else if (action === "CREATED") { bg = "#3b82f6"; label = "Created"; }
          return `<span style="display:inline-block; padding:2px 10px; background:${bg}; color:white; border-radius:12px; font-size:11px; font-weight:600; letter-spacing:0.5px;">${label}</span>`;
        },
      },
      {
        title: "Client",
        field: "clientName",
        headerFilter: "input",
        headerFilterPlaceholder: "Search client",
      },
      {
        title: "Item Type",
        field: "itemTypeLabel",
        width: 100,
        headerFilter: "input",
        headerFilterPlaceholder: "Search type",
      },
      {
        title: "Item",
        field: "itemName",
        headerFilter: "input",
        headerFilterPlaceholder: "Search item",
        formatter: (cell) => {
          return `<span style="color:#044A78; font-weight:600; display:block;">
                    ${cell.getValue() || "N/A"}
                  </span>`;
        },
      },
      {
        title: "Qty",
        field: "quantity",
        hozAlign: "center",
        headerFilter: "input",
        headerFilterPlaceholder: "Search qty",
      },
      {
        title: "Invoice #",
        field: "invoiceDisplay",
        hozAlign: "center",
        headerFilter: "input",
        headerFilterPlaceholder: "Search invoice",
      },
      {
        title: "Cancel Reason",
        field: "cancelReasonDisplay",
        headerFilter: "input",
        headerFilterPlaceholder: "Search reason",
        formatter: (cell) => {
          const val = cell.getValue();
          if (!val) return "-";
          return `<span title="${val}" style="color:#ef4444; font-weight:500;">${val}</span>`;
        },
      }
    ],
  });

  // Dropdown toggle
  const selector = document.getElementById("downloadSelector");
  const trigger = selector.querySelector(".download-selector__trigger");
  trigger.addEventListener("click", (e) => {
    e.stopPropagation();
    selector.classList.toggle("download-selector--active");
  });
  document.addEventListener("click", () => selector.classList.remove("download-selector--active"));

  // Downloads
  document.getElementById("download-pdf").addEventListener("click", () => {
    table.download("pdf", "order_logs.pdf", { orientation: "landscape", title: "Order Action Logs" });
    selector.classList.remove("download-selector--active");
  });
  document.getElementById("download-xlsx").addEventListener("click", () => {
    table.download("xlsx", "order_logs.xlsx", { sheetName: "OrderLogs" });
    selector.classList.remove("download-selector--active");
  });
</script>
