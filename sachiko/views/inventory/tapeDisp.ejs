<!-- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>

<!-- Tabulator CSS -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />
<link href="https://unpkg.com/tabulator-tables@5.6.2/dist/css/tabulator_modern.min.css" rel="stylesheet">
</head>

<body>
  <style>
    #master-table {
      width: 100%;
      flex: 1 1 auto;
      min-height: 0;
    }
  </style>
<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px" >
    <div class="indi-head">
      <h1>Tapes</h1>
      <div class="download-btns">
        <div class="download-selector" id="downloadSelector">
            <button class="download-selector__trigger">
              <span>
                <i class="fa-solid fa-file-arrow-down"></i>
                <span class="download-typo">Download</span>
              </span>
              <i class="fas fa-chevron-down download-selector__trigger-icon"></i>
            </button>
            <div class="download-selector__menu" id="downloads">
              <span class="download-selector__option" id="download-pdf">
                <i class="fas fa-file-pdf download-selector__option-icon"></i>
                <span>PDF</span>
              </span>
              <span class="download-selector__option" id="download-xlsx">
                <i class="fas fa-file-excel download-selector__option-icon"></i>
                <span>Excel</span>
              </span>
            </div>
          </div>
      </div>
    </div>

    <div class="table-spinner"><div class="spinner-circle"></div></div>
    <div id="master-table" class="tabulator tabulator-modern"></div>
</div>

  <!-- Tabulator JS -->
  <script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>
  <form id="deleteBindingForm" method="POST" style="display:none;"></form>
  <div class="logout-modal" id="deleteBindingModal" aria-hidden="true">
    <div class="logout-dialog" role="dialog" aria-modal="true" aria-labelledby="deleteBindingTitle">
      <h2 class="logout-title" id="deleteBindingTitle">Remove binding?</h2>
      <p class="logout-text">This will permanently remove this client item binding.</p>
      <div class="logout-actions">
        <button class="logout-btn" type="button" id="deleteBindingCancel">Cancel</button>
        <button class="logout-btn primary" type="button" id="deleteBindingConfirm">Remove</button>
      </div>
    </div>
  </div>

  <script id="table-data" type="application/json"><%- safeJson(jsonData) %></script>
  <script>
    // Render data from Express (passed into EJS)
    const rawData = JSON.parse(document.getElementById('table-data').textContent);

    // Flatten nested fields so Tabulator headerFilter works correctly
    const tableData = rawData.map(row => ({
      ...row,
      _userName: row.userId?.userName || "",
      _userContact: row.userId?.userContact || "",
      _userLocation: row.userId?.hoLocation || "",
      _clientName: row.userId?.clientName || "",
      _tapePaperType: row.tapeId?.tapePaperType || "",
      _tapeWidth: row.tapeId?.tapeWidth || "",
      _tapeMtrs: row.tapeId?.tapeMtrs || "",
      _tapeCoreId: row.tapeId?.tapeCoreId || "",
      _tapeMasterId: row.tapeId?._id || "",
    }));

    const withTextFilter = (column) => ({
      headerFilter: "input",
      headerFilterPlaceholder: "Search",
      ...column,
    });

    // Initialize Tabulator
    const table = new Tabulator("#master-table", {
      data: tableData,
      height: "100%",
      layout: "fitColumns",
      responsiveLayout: false,
      movableColumns: true,
      placeholder: "No data to display",
      columns: [
        {
          title: "Actions",
          hozAlign: "center",
          headerHozAlign: "center",
          width: 132,
          minWidth: 132,
          widthGrow: 0,
          widthShrink: 0,
          formatter: function (cell) {
            const row = cell.getRow().getData();
            if (!row._id) return '';
            return `
              <div style="display:flex;align-items:center;justify-content:center;gap:6px;">
                <button
                  onclick="window.location.href='/fairdesk/tape/compare/${row._id}'"
                  style="padding:2px 7px;background:#044A78;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;"
                  title="View Binding">
                  <i class="fa-solid fa-eye"></i>
                </button>
                <button
                  onclick="window.location.href='/fairdesk/tape-binding/edit/${row._id}'"
                  style="padding:2px 7px;background:#e67e22;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;"
                  title="Edit Binding">
                  <i class="fa-solid fa-pen-to-square"></i>
                </button>
                <button
                  onclick="promptDeleteBinding('${row._id}')"
                  style="padding:2px 7px;background:#d9534f;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;"
                  title="Remove Binding">
                  <i class="fa-solid fa-trash"></i>
                </button>
              </div>
            `;
          }
        },
        {
          title: "Status",
          field: "status",
          hozAlign: "center",
          headerFilter: "input",
          headerFilterPlaceholder: "Search",
          formatter: function (cell) {
            const val = cell.getValue() || "ACTIVE";
            const isActive = val === "ACTIVE";
            const bg = isActive ? "#28a745" : "#dc3545";
            return `<span style="background:${bg};color:#fff;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;">${val}</span>`;
          }
        },
        {
          title: "Stock",
          field: "stock",
          hozAlign: "center",
          headerFilter: "input",
          headerFilterPlaceholder: "Search",
          formatter: (cell) => {
            const row = cell.getRow().getData();
            const stock = row.stock ?? "-";
            return `<span style="font-weight:600">${stock}</span>`;
          }
        },
        {
          title: "Order",
          hozAlign: "center",
          formatter: (cell) => {
            const row = cell.getRow().getData();
            return `
              <button 
                onclick="window.location.href='/fairdesk/sales/order?type=TAPE&client=${encodeURIComponent(row._clientName)}&user=${row.userId?._id || ""}&item=${row._id}'"
                style="padding:2px 10px;background:#044A78;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;">
                <i class="fa-solid fa-cart-plus"></i>
              </button>
            `;
          }
        },
        withTextFilter({ title: "User Name", field: "_userName" }),
        withTextFilter({ title: "Client Item Type", field: "itemClientItemType" }),
        withTextFilter({ title: "User Contact", field: "_userContact" }),
        withTextFilter({ title: "Location", field: "_userLocation" }),
        withTextFilter({ title: "Client GSM", field: "clientTapeGsm" }),
        withTextFilter({ title: "Paper Type", field: "_tapePaperType" }),
        withTextFilter({ title: "Width", field: "_tapeWidth" }),
        withTextFilter({ title: "Mtrs", field: "_tapeMtrs" }),
        withTextFilter({ title: "Mtrs Del", field: "tapeMtrsDel" }),
        withTextFilter({ title: "Core ID", field: "_tapeCoreId" }),
        withTextFilter({ title: "Rate Per Roll", field: "tapeRatePerRoll" }),
        withTextFilter({ title: "Min Qty", field: "tapeMinQty" }),
        withTextFilter({ title: "Order Qty", field: "tapeOdrQty" }),
      ]
    });

    // Dropdown toggle
    const selector = document.getElementById("downloadSelector");
    const trigger = selector.querySelector(".download-selector__trigger");

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      selector.classList.toggle("download-selector--active");
    });

    // Close dropdown on outside click
    document.addEventListener("click", () => {
      selector.classList.remove("download-selector--active");
    });

    // PDF download
    document.getElementById("download-pdf").addEventListener("click", () => {
      table.download("pdf", "tapes.pdf", {
        orientation: "landscape",
        title: "Tapes Data",
      });
      selector.classList.remove("download-selector--active");
    });

    // Excel download
    document.getElementById("download-xlsx").addEventListener("click", () => {
      table.download("xlsx", "tape.xlsx", {
        sheetName: "Tapes",
      });
      selector.classList.remove("download-selector--active");
    });

    let bindingToDelete = "";
    const deleteModal = document.getElementById("deleteBindingModal");
    const deleteForm = document.getElementById("deleteBindingForm");
    const deleteConfirmBtn = document.getElementById("deleteBindingConfirm");
    const deleteCancelBtn = document.getElementById("deleteBindingCancel");
    const getCsrfToken = () => document.querySelector('meta[name="csrf-token"]')?.getAttribute("content") || "";

    window.promptDeleteBinding = function (bindingId) {
      bindingToDelete = String(bindingId || "");
      deleteModal.classList.add("show");
      deleteModal.setAttribute("aria-hidden", "false");
    };

    function closeDeleteModal() {
      deleteModal.classList.remove("show");
      deleteModal.setAttribute("aria-hidden", "true");
      bindingToDelete = "";
    }

    deleteCancelBtn.addEventListener("click", closeDeleteModal);
    deleteModal.addEventListener("click", (e) => {
      if (e.target === deleteModal) closeDeleteModal();
    });
    document.addEventListener("keydown", (e) => {
      if (!deleteModal.classList.contains("show")) return;
      if (e.key !== "Enter") return;
      if (e.target && ["INPUT", "TEXTAREA"].includes(e.target.tagName) && e.target !== deleteConfirmBtn) return;
      e.preventDefault();
      deleteConfirmBtn.click();
    });
    deleteConfirmBtn.addEventListener("click", () => {
      if (!bindingToDelete) return closeDeleteModal();
      let csrfInput = deleteForm.querySelector('input[name="_csrf"]');
      if (!csrfInput) {
        csrfInput = document.createElement("input");
        csrfInput.type = "hidden";
        csrfInput.name = "_csrf";
        deleteForm.appendChild(csrfInput);
      }
      csrfInput.value = getCsrfToken();
      deleteForm.action = `/fairdesk/tape-binding/delete/${bindingToDelete}`;
      deleteForm.submit();
    });

  </script>
</body>
