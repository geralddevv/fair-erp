<!-- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>

<!-- Tabulator CSS -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />
<link href="https://unpkg.com/tabulator-tables@5.6.2/dist/css/tabulator_modern.min.css" rel="stylesheet" />

<body>
  <div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
    <style>
      .header-action-btn {
        background-color: #f0f0f0;
        color: #044a78;
        padding: 2px 14px; /* Matches Download button padding exactly */
        font-size: 14px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        border-radius: 0.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transition: all 0.2s ease-in-out;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .header-action-btn:hover {
        background-color: #e4e4e4;
      }
      .stock-cell {
        background: #fbfdff;
        font-weight: 600;
      }
      #master-table {
        width: 100%;
        flex: 1 1 auto;
        min-height: 0;
      }
    </style>

    <div class="indi-head">
      <h1>TTR Master</h1>
      <div style="display: flex; gap: 10px; align-items: center">
        <button class="header-action-btn" onclick="window.location.href = '/fairdesk/form/ttr'">
          <i class="fa-solid fa-plus" style="margin-right: 4px"></i> TTR
        </button>

        <div class="download-selector" id="downloadSelector">
          <button class="download-selector__trigger">
            <span>
              <i class="fa-solid fa-file-arrow-down"></i>
              <span class="download-typo">Download</span>
            </span>
            <i class="fas fa-chevron-down download-selector__trigger-icon"></i>
          </button>
          <div class="download-selector__menu" id="downloads">
            <span class="download-selector__option" id="download-pdf">
              <i class="fas fa-file-pdf download-selector__option-icon"></i>
              <span>PDF</span>
            </span>
            <span class="download-selector__option" id="download-xlsx">
              <i class="fas fa-file-excel download-selector__option-icon"></i>
              <span>Excel</span>
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="table-spinner"><div class="spinner-circle"></div></div>
    <div id="master-table" class="tabulator tabulator-modern"></div>
  </div>

  <!-- Tabulator JS -->
  <script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>

  <script>
    // Parse data from Express
    const tableData = <%- safeJson(jsonData) %>;

    const withTextFilter = (column) => ({
      headerFilter: "input",
      headerFilterPlaceholder: "Search",
      minWidth: 100, // Ensure columns don't shrink too much
      ...column,
    });

    // Initialize Tabulator
    const baseColumns = [
      {
        title: "",
        formatter: function (cell) {
          const row = cell.getRow().getData();
          if (!row._id) return "";
          return `
            <button
              onclick="window.location.href='/fairdesk/ttr/profile/${row._id}'"
              style="padding:2px 10px;background:#044A78;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;">
              <i class="fa-solid fa-eye"></i>
            </button>
          `;
        }
      },
      {
        title: "Product ID",
        field: "ttrProductId",
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        width: 150,
        minWidth: 140,
      },
      {
        title: "Stock",
        field: "stock",
        hozAlign: "left",
        headerHozAlign: "left",
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        width: 90,
        minWidth: 80,
        maxWidth: 100,
        widthGrow: 0,
        widthShrink: 0,
        cssClass: "stock-cell",
        formatter: (cell) => {
          const value = Number(cell.getValue() || 0);
          if (value === 0) return "";
          const row = cell.getRow().getData();
          return `<a href="/fairdesk/ttr/profile/${row._id}" style="color:#044A78;text-decoration:underline;font-weight:700;">${value}</a>`;
        },
        cellClick: (e, cell) => {
          const row = cell.getRow().getData();
          if (row._id && Number(row.stock) !== 0) {
            window.location.href = `/fairdesk/ttr/profile/${row._id}`;
          }
        },
      },
      {
        title: "B Clients",
        field: "bindingCount",
        hozAlign: "left",
        headerHozAlign: "left",
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        width: 120,
        minWidth: 100,
        formatter: (cell) => {
          const value = cell.getValue();
          if (!value || value === 0) return "";
          const row = cell.getRow().getData();
          return `<a href="/fairdesk/ttr/master-view/clients/${row._id}" style="color:#044A78;text-decoration:underline;font-weight:700;">${value}</a>`;
        },
        cellClick: (e, cell) => {
          const row = cell.getRow().getData();
          const val = Number(cell.getValue());
          if (row._id && val > 0) {
            window.location.href = `/fairdesk/ttr/master-view/clients/${row._id}`;
          }
        },
      },
      {
        title: "B Vendors",
        field: "vendorBindingCount",
        hozAlign: "left",
        headerHozAlign: "left",
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        width: 120,
        minWidth: 100,
        formatter: (cell) => {
          const value = cell.getValue();
          if (!value || value === 0) return "";
          const row = cell.getRow().getData();
          return `<a href="/fairdesk/ttr/master-view/vendors/${row._id}" style="color:#044A78;text-decoration:underline;font-weight:700;">${value}</a>`;
        },
        cellClick: (e, cell) => {
          const row = cell.getRow().getData();
          const val = Number(cell.getValue());
          if (row._id && val > 0) {
            window.location.href = `/fairdesk/ttr/master-view/vendors/${row._id}`;
          }
        },
      },
      {
        title: "Material Code",
        field: "ttrMaterialCode",
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
      },
      {
        title: "Type",
        field: "ttrType",
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
      },
      withTextFilter({ title: "Color", field: "ttrColor" }),
      withTextFilter({ title: "Width", field: "ttrWidth" }),
      withTextFilter({ title: "Mtrs", field: "ttrMtrs" }),
      withTextFilter({ title: "Ink Face", field: "ttrInkFace" }),
      withTextFilter({ title: "Core ID", field: "ttrCoreId" }),
      withTextFilter({ title: "Core Len", field: "ttrCoreLength" }),
      withTextFilter({ title: "Notch", field: "ttrNotch" }),
      withTextFilter({ title: "Winding", field: "ttrWinding" }),
      withTextFilter({ title: "Min Stock Qty", field: "ttrMinQty" }),
    ];

    const normalizedBaseColumns = baseColumns.map((column, index) =>
      index === 0
        ? {
            ...column,
            width: 56,
            minWidth: 56,
            widthGrow: 0,
            widthShrink: 0,
            responsive: 0,
            hozAlign: "center",
            headerSort: false,
          }
        : {
            ...column,
            minWidth: 96,
            widthGrow: 1,
            widthShrink: 1,
            responsive: index + 1,
          },
    );

    const table = new Tabulator("#master-table", {
      data: tableData,
      height: "100%",
      // layout: "fitColumns",
      responsiveLayout: false,
      movableColumns: true,
      placeholder: "No data to display",
      columns: normalizedBaseColumns,
    });

    // Dropdown toggle
    const selector = document.getElementById("downloadSelector");
    const trigger = selector.querySelector(".download-selector__trigger");

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      selector.classList.toggle("download-selector--active");
    });

    document.addEventListener("click", () => {
      selector.classList.remove("download-selector--active");
    });

    // PDF download
    document.getElementById("download-pdf").addEventListener("click", () => {
      table.download("pdf", "ttr-master.pdf", {
        orientation: "landscape",
        title: "TTR Master Data",
      });
      selector.classList.remove("download-selector--active");
    });

    // Excel download
    document.getElementById("download-xlsx").addEventListener("click", () => {
      table.download("xlsx", "ttr-master.xlsx", {
        sheetName: "TTR Master",
      });
      selector.classList.remove("download-selector--active");
    });
  </script>
</body>
