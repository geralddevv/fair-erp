<% layout('/layout/boilerplate') -%>

<div class="main-content">
  <form
    class="needs-validation"
    action="/fairdesk/vendor-item/edit/tafeta/<%= binding._id %>"
    method="post"
    autocomplete="off"
    novalidate
  >
    <input type="hidden" name="returnTo" value="<%= returnTo || '' %>" />

    <div
      class="span-full form-subheading gap"
      style="display: flex; justify-content: space-between; align-items: center"
    >
      <h1 style="margin: 0">Edit Vendor Tafeta Binding</h1>
    </div>

    <div class="span-seven">
      <label>Tafeta ID</label>
      <input
        type="text"
        class="form-control input-tag"
        value="<%= binding.tafetaId?.tafetaProductId || 'N/A' %>"
        readonly
      />
    </div>

    <div class="span-six">
      <label>Vendor Name</label>
      <input
        type="text"
        class="form-control input-tag"
        value="<%= binding.vendorUserId?.vendorName || '' %>"
        readonly
      />
    </div>

    <div class="span-six">
      <label>Vendor User</label>
      <input type="text" class="form-control input-tag" value="<%= binding.vendorUserId?.userName || '' %>" readonly />
    </div>

    <div class="span-six">
      <label>Material Code</label>
      <input
        type="text"
        class="form-control input-tag"
        value="<%= binding.tafetaId?.tafetaMaterialCode || '' %>"
        readonly
      />
    </div>

    <div class="span-seven">
      <label>Material Type</label>
      <input
        type="text"
        class="form-control input-tag"
        value="<%= binding.tafetaId?.tafetaMaterialType || '' %>"
        readonly
      />
    </div>

    <div class="span-four">
      <label>GSM</label>
      <input type="text" class="form-control input-tag" value="<%= binding.tafetaId?.tafetaGsm || '' %>" readonly />
    </div>

    <div class="span-four">
      <label>Color</label>
      <input type="text" class="form-control input-tag" value="<%= binding.tafetaId?.tafetaColor || '' %>" readonly />
    </div>

    <div class="span-five">
      <label>Width</label>
      <input type="text" class="form-control input-tag" value="<%= binding.tafetaId?.tafetaWidth || '' %>" readonly />
    </div>

    <div class="span-five">
      <label>Meters</label>
      <input type="text" class="form-control input-tag" value="<%= binding.tafetaId?.tafetaMtrs || '' %>" readonly />
    </div>

    <div class="span-five">
      <label>Core Len</label>
      <input type="text" class="form-control input-tag" value="<%= binding.tafetaId?.tafetaCoreLen || '' %>" readonly />
    </div>

    <div class="span-five">
      <label>Notch</label>
      <input type="text" class="form-control input-tag" value="<%= binding.tafetaId?.tafetaNotch || '' %>" readonly />
    </div>

    <div class="span-four">
      <label>Core ID</label>
      <input type="text" class="form-control input-tag" value="<%= binding.tafetaId?.tafetaCoreId || '' %>" readonly />
    </div>

    <div class="span-full form-subheading">
      <h1>Vendor Overrides</h1>
    </div>

    <div class="span-dual">
      <label>Vendor Material Code</label>
      <input
        type="text"
        name="vendorTafetaMaterialCode"
        class="form-control"
        value="<%= binding.vendorTafetaMaterialCode %>"
        required
      />
    </div>

    <div class="span-dual">
      <label>Vendor Material Type</label>
      <input
        type="text"
        name="vendorTafetaMaterialType"
        class="form-control"
        value="<%= binding.vendorTafetaMaterialType || '' %>"
        required
      />
    </div>

    <div class="span-dual">
      <label>Vendor GSM</label>
      <input type="text" name="vendorTafetaGsm" class="form-control" value="<%= binding.vendorTafetaGsm %>" required />
    </div>

    <div class="span-dual">
      <label>MSQ</label>
      <input
        type="number"
        name="tafetaMinQty"
        class="form-control"
        value="<%= binding.tafetaMinQty %>"
        min="0"
        required
      />
    </div>

    <div class="span-dual">
      <label>Rate</label>
      <input
        type="number"
        name="tafetaRatePerRoll"
        class="form-control"
        value="<%= binding.tafetaRatePerRoll %>"
        step="0.01"
        min="0"
      />
    </div>

    <div class="span-full btn-grp" style="flex-direction: row-reverse">
      <button class="submit-btn" type="submit">Update Vendor Tafeta Binding</button>
      <button type="button" id="cancelBtn">Cancel</button>
    </div>
  </form>
</div>

<script>
  const form = document.querySelector("form");
  const submitBtn = form.querySelector('button[type="submit"]');
  const returnTo = <%- safeJson(returnTo || "") %>;

  document.getElementById("cancelBtn").addEventListener("click", () => {
    if (returnTo) {
      window.location.href = returnTo;
      return;
    }
    window.history.back();
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    submitBtn.disabled = true;

    try {
      const res = await fetch(form.action, {
        method: "POST",
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(Object.fromEntries(new FormData(form))),
      });
      const data = await res.json();

      if (!res.ok || !data?.success) {
        submitBtn.disabled = false;
        if (window.showToast) window.showToast(data?.message || "Failed to update vendor binding", true);
        return;
      }

      window.location.href = data.redirect || returnTo || "/fairdesk/vendor/coordinator/view";
    } catch (err) {
      console.error(err);
      submitBtn.disabled = false;
      if (window.showToast) window.showToast("Failed to update vendor binding", true);
    }
  });
</script>
