<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content="<%= csrfToken %>" />
    <title>Sachiko - <%= title %></title>
    <link rel="icon" href="/assets/sachikofavicon.png" type="image/png" />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/common.css?v=5" />
    <% if (CSS) { %>
    <link rel="stylesheet" href="/css/<%= CSS %>" />
    <% } %>
  </head>
    <div id="fd-toast" class="toast-notification" style="display: none; opacity: 0; pointer-events: auto;">
      <span id="fd-toast-message"></span>
      <span class="toast-close" id="fd-toast-close">&times;</span>
    </div>

    <main class="auth-container">
      <%- body -%>
    </main>

    <style>
      .toast-notification {
        position: fixed;
        bottom: 24px;
        right: 24px;
        background: #ffffff;
        color: #1e293b;
        padding: 16px 48px 16px 20px;
        border-radius: 12px;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        z-index: 10000;
        font-family: inherit;
        font-size: 15px;
        font-weight: 500;
        border-left: 5px solid #044A78;
        display: flex;
        align-items: center;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        transform: translateX(120%);
        min-width: 320px;
        max-width: 450px;
      }
      .toast-success { border-left-color: #10b981; background: #f0fdf4; color: #166534; }
      .toast-error { border-left-color: #ef4444; background: #fef2f2; color: #991b1b; }
      .toast-warning { border-left-color: #f59e0b; background: #fffbeb; color: #92400e; }
      .toast-info { border-left-color: #3b82f6; background: #eff6ff; color: #1e40af; }
      
      .toast-close {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        font-size: 20px;
        color: currentColor;
        opacity: 0.6;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        transition: all 0.2s;
      }
      .toast-close:hover { opacity: 1; background: rgba(0,0,0,0.05); }
    </style>

    <script>
      function showToast(message, type = 'info') {
        const toast = document.getElementById('fd-toast');
        const msgSpan = document.getElementById('fd-toast-message');
        if (!toast || !msgSpan) return;

        toast.className = 'toast-notification toast-' + type;
        msgSpan.textContent = message;
        toast.style.display = 'flex';
        
        requestAnimationFrame(() => {
          toast.style.opacity = '1';
          toast.style.transform = 'translateX(0)';
        });

        const closeBtn = document.getElementById('fd-toast-close');
        const hide = () => {
          toast.style.opacity = '0';
          toast.style.transform = 'translateX(120%)';
          setTimeout(() => { toast.style.display = 'none'; }, 400);
        };
        
        closeBtn.onclick = hide;
        setTimeout(hide, 6000);
      }

      window.addEventListener('DOMContentLoaded', () => {
        const urlParams = new URLSearchParams(window.location.search);
        const reason = urlParams.get('reason');
        const sessionEndReasons = new Set(['timeout', 'session-ended', 'session-expired', 'expired']);

        if (sessionEndReasons.has(reason)) {
          showToast('Your session ended. Please sign in again to continue.', 'warning');
          // Clean up URL without refreshing
          const newUrl = window.location.pathname;
          window.history.replaceState({}, '', newUrl);
        }
      });
    </script>
  </body>
</html>
