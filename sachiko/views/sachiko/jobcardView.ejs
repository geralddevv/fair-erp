<% layout('/layout/boilerplate') -%>

<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />

<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
  <style>
    #master-table { width: 100%; flex: 1 1 auto; min-height: 0; }
    .tabulator-edit-list { scrollbar-width: none !important; -ms-overflow-style: none !important; }
    .tabulator-edit-list::-webkit-scrollbar { display: none !important; }
    .header-action-btn {
      background-color: #f0f0f0; color: #044a78;
      padding: 2px 14px; font-size: 14px; font-weight: 500;
      border: none; cursor: pointer; border-radius: 0.5rem;
      box-shadow: 0 4px 6px -1px rgba(0,0,0,.1);
      transition: all 0.2s ease-in-out;
      display: flex; align-items: center; justify-content: center;
    }
    .header-action-btn:hover { background-color: #e4e4e4; }
  </style>

  <div class="indi-head">
    <h1>Job Card View</h1>
    <div style="display: flex; gap: 10px; align-items: center">
      <button class="header-action-btn" onclick="window.location.href='/sachiko/jobcard/form'">
        <i class="fa-solid fa-plus" style="margin-right: 4px"></i> New
      </button>
      <div class="download-selector" id="downloadSelector">
        <button class="download-selector__trigger">
          <span><i class="fa-solid fa-file-arrow-down"></i> Download</span>
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="download-selector__menu">
          <div class="download-selector__option" id="download-xlsx"><i class="fas fa-file-excel"></i> Excel</div>
        </div>
      </div>
    </div>
  </div>

  <div class="table-spinner"><div class="spinner-circle"></div></div>
  <div id="master-table"></div>
</div>

<script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/file-saver@2.0.5/dist/FileSaver.min.js"></script>

<script>
  const downloadSelector = document.getElementById("downloadSelector");
  const triggerBtn = downloadSelector.querySelector(".download-selector__trigger");
  triggerBtn.addEventListener("click", (e) => { e.stopPropagation(); downloadSelector.classList.toggle("download-selector--active"); });
  document.addEventListener("click", () => downloadSelector.classList.remove("download-selector--active"));

  const raw = <%- safeJson(jsonData) %>;

  const tableData = raw.map(jc => ({
    jobCardId:    jc.jobCardId,
    date:         jc.date ? new Date(jc.date).toLocaleDateString("en-GB") : "-",
    productCode:  jc.productCode,
    quantity:     jc.quantity ?? "-",
    lotNo:        jc.lotNo || "-",
    fsRollDrumNo: jc.faceStock?.rollDrumNo || "-",
    fsCode:       jc.faceStock?.code       || "-",
    fsGsmMic:     jc.faceStock?.gsmMic     || "-",
    fsSize:       jc.faceStock?.size       || "-",
    adRollDrumNo: jc.adhesive?.rollDrumNo  || "-",
    adCode:       jc.adhesive?.code        || "-",
    adGsmMic:     jc.adhesive?.gsmMic      || "-",
    adSize:       jc.adhesive?.size        || "-",
    rlRollDrumNo: jc.releaseLiner?.rollDrumNo || "-",
    rlCode:       jc.releaseLiner?.code       || "-",
    rlGsmMic:     jc.releaseLiner?.gsmMic     || "-",
    rlSize:       jc.releaseLiner?.size       || "-",
  }));

  const withTextFilter = (col) => ({ headerFilter: "input", headerFilterPlaceholder: "Search", minWidth: 100, ...col });

  const table = new Tabulator("#master-table", {
    data: tableData,
    height: "100%",
    initialSort: [{ column: "date", dir: "desc" }],
    placeholder: "No job cards found",
    columns: [
      withTextFilter({ title: "Job Card ID",   field: "jobCardId",    width: 160, formatter: (cell) => `<span style="font-weight:700;color:#044a78;">${cell.getValue()}</span>` }),
      withTextFilter({ title: "Date",          field: "date",         width: 110 }),
      withTextFilter({ title: "Product Code",  field: "productCode",  minWidth: 140, formatter: (cell) => `<span style="font-weight:600;color:#03365a;">${cell.getValue()}</span>` }),
      withTextFilter({ title: "Quantity",      field: "quantity",     width: 100 }),
      withTextFilter({ title: "Lot No",        field: "lotNo",        minWidth: 110 }),
      withTextFilter({ title: "FS Roll/Drum",  field: "fsRollDrumNo", minWidth: 120 }),
      withTextFilter({ title: "FS Code",       field: "fsCode",       minWidth: 110 }),
      withTextFilter({ title: "FS GSM/MIC",    field: "fsGsmMic",     minWidth: 110 }),
      withTextFilter({ title: "FS Size",       field: "fsSize",       minWidth: 100 }),
      withTextFilter({ title: "AD Roll/Drum",  field: "adRollDrumNo", minWidth: 120 }),
      withTextFilter({ title: "AD Code",       field: "adCode",       minWidth: 110 }),
      withTextFilter({ title: "AD GSM/MIC",    field: "adGsmMic",     minWidth: 110 }),
      withTextFilter({ title: "AD Size",       field: "adSize",       minWidth: 100 }),
      withTextFilter({ title: "RL Roll/Drum",  field: "rlRollDrumNo", minWidth: 120 }),
      withTextFilter({ title: "RL Code",       field: "rlCode",       minWidth: 110 }),
      withTextFilter({ title: "RL GSM/MIC",    field: "rlGsmMic",     minWidth: 110 }),
      withTextFilter({ title: "RL Size",       field: "rlSize",       minWidth: 100 }),
    ],
  });

  document.getElementById("download-xlsx").addEventListener("click", () =>
    table.download("xlsx", "sachiko-jobcards.xlsx", { sheetName: "Job Cards" }));
</script>

<% if (notification && notification.length) { %>
<script>
  const jcFlash = <%- safeJson(notification[0]) %>;
  const jcFlashType = /failed|not found|error/i.test(String(jcFlash)) ? "error" : "success";
  const showJcFlash = () => {
    if (typeof hideStaticToast === "function") hideStaticToast();
    if (typeof showToast === "function") showToast(jcFlash, jcFlashType);
  };
  document.readyState === "loading"
    ? document.addEventListener("DOMContentLoaded", showJcFlash, { once: true })
    : showJcFlash();
</script>
<% } %>
