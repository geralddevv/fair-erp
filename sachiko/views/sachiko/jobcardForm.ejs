<% layout('/layout/boilerplate') %>

<style>
  .choices[data-type*="select-one"]::after {
    display: block !important;
    content: "" !important;
    width: 12px !important;
    height: 8px !important;
    border-style: none !important;
    border-width: 0 !important;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%23044a78' stroke-width='2' fill='none'/%3E%3C/svg%3E") !important;
    background-repeat: no-repeat !important;
    background-size: contain !important;
    position: absolute !important;
    right: 11.5px !important;
    top: 50% !important;
    margin-top: 0 !important;
    transform: translateY(-50%) !important;
  }
  .choices[data-type*="select-one"].is-open::after {
    transform: translateY(-50%) rotate(180deg) !important;
  }

  .jc-table {
    width: 100%;
    border-collapse: collapse;
    background: #ffffff;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(4,74,120,0.08);
  }
  .jc-table th {
    background: #044a78;
    color: #ffffff;
    font-size: 13px;
    font-weight: 600;
    padding: 10px 14px;
    text-align: left;
    letter-spacing: 0.02em;
  }
  .jc-table td {
    padding: 8px 10px;
    border-bottom: 1px solid #e2e8f0;
    vertical-align: middle;
  }
  .jc-table tr:last-child td {
    border-bottom: none;
  }
  .jc-table td:first-child {
    font-size: 13px;
    font-weight: 700;
    color: #03365a;
    white-space: nowrap;
    width: 120px;
    background: #f0f7ff;
  }
  .jc-table input.form-control {
    padding: 8px 10px !important;
    font-size: 13px !important;
    height: auto !important;
  }

  .jc-log-table {
    width: 100%;
    border-collapse: collapse;
    background: #ffffff;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(4,74,120,0.08);
  }
  .jc-log-table th {
    background: #044a78;
    color: #ffffff;
    font-size: 13px;
    font-weight: 600;
    padding: 9px 10px;
    text-align: center;
    letter-spacing: 0.02em;
    border-right: 1px solid rgba(255,255,255,0.25);
  }
  .jc-log-table th:last-child {
    border-right: none;
  }

  .jc-log-table th.group-head {
    border-bottom: 1px solid rgba(255,255,255,0.3);
  }
  .jc-log-table th.sub-head {
    background: #055690;
    font-size: 12px;
    font-weight: 500;
    padding: 7px 10px;
  }
  .jc-log-table td {
    padding: 6px 8px;
    border-bottom: 1px solid #e2e8f0;
    border-right: 1px solid #e2e8f0;
    vertical-align: middle;
  }
  .jc-log-table td:last-child {
    border-right: none;
  }
  .jc-log-table tr:last-child td {
    border-bottom: none;
  }
  .jc-log-table input.form-control {
    padding: 6px 8px !important;
    font-size: 13px !important;
    height: auto !important;
    min-width: 0;
  }
</style>

<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px">
  <form
    action="/sachiko/jobcard/form"
    method="POST"
    class="needs-validation"
    autocomplete="off"
    novalidate
  >
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <div class="span-full form-heading">
      <h1>Job Card Entry</h1>
    </div>

    <!-- Row 1: Date, Product Code, Quantity, Lot No -->
    <div class="span-dual">
      <label for="date">Date</label>
      <input
        type="date"
        id="date"
        name="date"
        class="form-control"
        value="<%= new Date().toISOString().slice(0,10) %>"
        required
      />
    </div>

    <div class="span-dual">
      <label for="productCode">Product Code</label>
      <select id="productCode" name="productCode" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Select product code</option>
        <% datasheets.forEach(ds => { %>
        <option
          value="<%= ds.productCode %>"
          data-fs-type="<%= ds.facestock?.facestockType || '' %>"
          data-fs-gsm="<%= ds.facestock?.facestockGsm != null ? ds.facestock.facestockGsm + ' GSM' : '' %>"
          data-fs-mic="<%= ds.facestock?.facestockMicron != null ? ds.facestock.facestockMicron + ' MIC' : '' %>"
          data-ad-type="<%= ds.adhesive?.adhesiveType || '' %>"
          data-ad-gsm="<%= ds.adhesive?.adhesiveGsm != null ? ds.adhesive.adhesiveGsm + ' GSM' : '' %>"
          data-rl-type="<%= ds.releaseLiner?.releaseLinerType || '' %>"
          data-rl-gsm="<%= ds.releaseLiner?.releaseLinerGsm != null ? ds.releaseLiner.releaseLinerGsm + ' GSM' : '' %>"
        ><%= ds.productCode %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-dual">
      <label for="quantity">Quantity</label>
      <input
        type="number"
        id="quantity"
        name="quantity"
        class="form-control"
        placeholder="Enter quantity"
        min="0"
        step="any"
      />
    </div>

    <div class="span-dual">
      <label for="lotNo">Lot No</label>
      <input
        type="text"
        id="lotNo"
        name="lotNo"
        class="form-control"
        value="<%= previewLotNo %>"
        readonly
        style="background:#f0f7ff; color:#044a78; font-weight:700; cursor:default;"
      />
    </div>

    <!-- Row 2: Materials Table -->
    <div class="span-full">
      <table class="jc-table" style="table-layout:fixed;">
        <colgroup>
          <col style="width:120px;" />
          <col style="width:160px;" />
          <col style="width:120px;" />
          <col style="width:100px;" />
          <col />
        </colgroup>
        <thead>
          <tr>
            <th>Items</th>
            <th>Code</th>
            <th>GSM / MIC</th>
            <th>Size</th>
            <th>Roll / Drum No</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Face Stock</td>
            <td><input type="text" name="fsCode"       id="fsCode"    class="form-control" placeholder="Code" /></td>
            <td><input type="text" name="fsGsmMic"     id="fsGsmMic"  class="form-control" placeholder="GSM / MIC" /></td>
            <td><input type="text" name="fsSize"       class="form-control" placeholder="Size" /></td>
            <td><input type="text" name="fsRollDrumNo" class="form-control" placeholder="Roll No" /></td>
          </tr>
          <tr>
            <td>Adhesive</td>
            <td><input type="text" name="adCode"       id="adCode"   class="form-control" placeholder="Code" readonly /></td>
            <td><input type="text" name="adGsmMic"     id="adGsmMic" class="form-control" placeholder="GSM / MIC" readonly style="background:#f0f7ff;color:#044a78;font-weight:600;cursor:default;" /></td>
            <td><input type="text" name="adSize" id="adSize" class="form-control" placeholder="Size" readonly style="background:#f0f7ff;color:#044a78;font-weight:600;cursor:default;" /></td>
            <td><input type="text" name="adRollDrumNo" class="form-control" placeholder="Drum No" /></td>
          </tr>
          <tr>
            <td>Release Liner</td>
            <td><input type="text" name="rlCode"       id="rlCode"   class="form-control" placeholder="Code" /></td>
            <td><input type="text" name="rlGsmMic"     id="rlGsmMic" class="form-control" placeholder="GSM / MIC" /></td>
            <td><input type="text" name="rlSize"       class="form-control" placeholder="Size" /></td>
            <td><input type="text" name="rlRollDrumNo" class="form-control" placeholder="Roll No" /></td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Machine No, Operator & Helper -->
    <div class="span-full" style="flex-direction: row; align-items: center; gap: 2rem; padding: 10px;">
      <div style="flex:1; display:flex; align-items:center; gap:0.75rem;">
        <label for="machineNo" style="white-space: nowrap; margin: 0; font-size: 13px; font-weight: 600; color: #03365a; min-width: fit-content">Machine No</label>
        <input type="text" id="machineNo" name="machineNo" class="form-control" placeholder="Enter machine no" />
      </div>
      <div style="flex:1; display:flex; align-items:center; gap:0.75rem;">
        <label for="operatorName" style="white-space: nowrap; margin: 0; font-size: 13px; font-weight: 600; color: #03365a; min-width: fit-content">Operator Name</label>
        <input type="text" id="operatorName" name="operatorName" class="form-control" placeholder="Enter operator name" />
      </div>
      <div style="flex:1; display:flex; align-items:center; gap:0.75rem;">
        <label for="helperName" style="white-space: nowrap; margin: 0; font-size: 13px; font-weight: 600; color: #03365a; min-width: fit-content">Helper Name</label>
        <input type="text" id="helperName" name="helperName" class="form-control" placeholder="Enter helper name" />
      </div>
    </div>

    <!-- Job Setting Table -->
    <div class="span-full form-subheading" style="display: flex; align-items: center; gap: 12px;">
      <h1>Job Setting</h1>
      <div style="display: inline-flex; align-items: center; gap: 6px; margin-left: 10px;">
        <button type="button" id="jsMinus" style="width: 30px; height: 30px; border: 1px solid #044A78; background: white; color: #044A78; border-radius: 4px; font-size: 18px; line-height: 1; cursor: pointer;">-</button>
        <input type="text" id="jsCount" style="width: 56px; height: 30px; text-align: center; border: 1px solid #044A78; border-radius: 4px; font-size: 14px;" class="form-control" value="1" readonly />
        <button type="button" id="jsPlus" style="width: 30px; height: 30px; border: 1px solid #044A78; background: white; color: #044A78; border-radius: 4px; font-size: 18px; line-height: 1; cursor: pointer;">+</button>
      </div>
    </div>

    <div class="span-full">
      <table class="jc-log-table">
        <thead>
          <tr>
            <th style="width:36px; text-align:center;">#</th>
            <th>Mtrs</th>
            <th style="text-align:center;">Start</th>
            <th>Mtrs</th>
            <th style="text-align:center;">Stop</th>
          </tr>
        </thead>
        <tbody id="jsTableBody">
          <!-- rows injected by JS -->
        </tbody>
      </table>
    </div>

    <!-- Production Log Table -->
    <div class="span-full form-subheading" style="display: flex; align-items: center; gap: 12px;">
      <h1>Production Log</h1>
      <div style="display: inline-flex; align-items: center; gap: 6px; margin-left: 10px;">
        <button type="button" id="logMinus" style="width: 30px; height: 30px; border: 1px solid #044A78; background: white; color: #044A78; border-radius: 4px; font-size: 18px; line-height: 1; cursor: pointer;">-</button>
        <input type="text" id="logCount" style="width: 56px; height: 30px; text-align: center; border: 1px solid #044A78; border-radius: 4px; font-size: 14px;" class="form-control" value="1" readonly />
        <button type="button" id="logPlus" style="width: 30px; height: 30px; border: 1px solid #044A78; background: white; color: #044A78; border-radius: 4px; font-size: 18px; line-height: 1; cursor: pointer;">+</button>
      </div>
    </div>

    <div class="span-full">
      <table class="jc-log-table">
        <thead>
          <tr>
            <th rowspan="2" style="vertical-align: middle; width: 36px">#</th>
            <th rowspan="2" style="vertical-align: middle; text-align: left; padding-left: 12px">Deckle ID</th>
            <th colspan="3" class="group-head">Time</th>
            <th rowspan="2" style="vertical-align: middle">Meters</th>
            <th colspan="2" class="group-head">Face</th>
            <th colspan="2" class="group-head">Release</th>
          </tr>
          <tr>
            <th class="sub-head">Start</th>
            <th class="sub-head">End</th>
            <th class="sub-head">Timer</th>
            <th class="sub-head">Joint</th>
            <th class="sub-head">Mtr</th>
            <th class="sub-head">Joint</th>
            <th class="sub-head">Mtr</th>
          </tr>
        </thead>
        <tbody id="logTableBody">
          <!-- rows injected by JS -->
        </tbody>
        <tfoot>
          <tr style="background: #044a78;">
            <td style="text-align:center; font-size:12px; font-weight:700; color:#ffffff; white-space:nowrap; padding: 6px 8px;">Total</td>
            <td colspan="7" style="padding: 6px 8px">
              <input type="text" name="totalMeter" class="form-control" placeholder="Total Meter" style="padding:6px 8px !important; font-size:13px !important; height:auto !important;" />
            </td>
            <td colspan="2" style="padding: 6px 8px">
              <input type="text" name="sqMtr" class="form-control" placeholder="SQ Mtr" style="padding:6px 8px !important; font-size:13px !important; height:auto !important;" />
            </td>
          </tr>
        </tfoot>
      </table>
    </div>

    <div class="btn-grp span-full">
      <button type="submit">Save Job Card</button>
    </div>
  </form>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const productSelect = document.getElementById("productCode");

    const choices = new Choices(productSelect, {
      searchEnabled: true,
      shouldSort: false,
      itemSelectText: "",
      searchPlaceholderValue: "Search product code…",
    });

    function autofillFromSelection() {
      const sel = productSelect.options[productSelect.selectedIndex];
      if (!sel || !sel.value) return;

      const fsType   = sel.dataset.fsType  || "";
      const fsMic    = sel.dataset.fsMic   || "";
      const fsGsmVal = sel.dataset.fsGsm   || "";
      const adType   = sel.dataset.adType  || "";
      const adGsmVal = sel.dataset.adGsm   || "";
      const rlType   = sel.dataset.rlType  || "";
      const rlGsmVal = sel.dataset.rlGsm   || "";

      document.getElementById("fsCode").value   = fsType;
      document.getElementById("fsGsmMic").value = fsMic || fsGsmVal;
      document.getElementById("adCode").value   = adType;
      document.getElementById("adGsmMic").value = adGsmVal;
      document.getElementById("adSize").value   = adGsmVal;
      document.getElementById("rlCode").value   = rlType;
      document.getElementById("rlGsmMic").value = rlGsmVal;
    }

    productSelect.addEventListener("change", autofillFromSelection);

    /* ── Job Setting dynamic rows ── */
    const jsBody  = document.getElementById("jsTableBody");
    const jsCount = document.getElementById("jsCount");
    const jsPlus  = document.getElementById("jsPlus");
    const jsMinus = document.getElementById("jsMinus");

    function jsRenumber() {
      Array.from(jsBody.rows).forEach((row, i) => { row.cells[0].textContent = i + 1; });
      jsCount.value = jsBody.rows.length;
    }

    function createJsRow() {
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td style="text-align:center; font-weight:600; color:#03365a; background:#f0f7ff;"></td>
        <td><input type="number" name="jsMtrs1" class="form-control js-mtrs1" placeholder="Mtrs" min="0" step="any" required /></td>
        <td style="text-align:center; white-space:nowrap; min-width:110px;">
          <span class="js-start-display" style="font-size:12px; font-weight:700; color:#03365a; margin-right:4px;">—</span>
          <input type="hidden" name="jsStart" class="js-start-input" />
          <button type="button" class="js-start-btn" disabled
            style="width:32px; height:26px; padding:0; font-size:12px; border:none; border-radius:4px; cursor:not-allowed; background:#d1d5db; color:white; display:inline-flex; align-items:center; justify-content:center; flex-shrink:0;">
            <i class="fa-solid fa-play"></i>
          </button>
        </td>
        <td><input type="number" name="jsMtrs2" class="form-control js-mtrs2" placeholder="Mtrs" min="0" step="any" /></td>
        <td style="text-align:center; white-space:nowrap; min-width:110px;">
          <span class="js-stop-display" style="font-size:12px; font-weight:700; color:#dc2626; margin-right:4px;">—</span>
          <input type="hidden" name="jsStop" class="js-stop-input" />
          <button type="button" class="js-stop-btn" disabled
            style="width:32px; height:26px; padding:0; font-size:12px; border:none; border-radius:4px; cursor:not-allowed; background:#d1d5db; color:white; display:inline-flex; align-items:center; justify-content:center; flex-shrink:0;">
            <i class="fa-solid fa-stop"></i>
          </button>
        </td>`;
      return tr;
    }

    jsBody.addEventListener("input", (e) => {
      const row = e.target.closest("tr");
      if (!row) return;
      if (e.target.classList.contains("js-mtrs1")) {
        const btn = row.querySelector(".js-start-btn");
        const has = e.target.value.trim() !== "";
        btn.disabled = !has;
        btn.style.background = has ? "#10b981" : "#d1d5db";
        btn.style.cursor = has ? "pointer" : "not-allowed";
      }
      if (e.target.classList.contains("js-mtrs2")) {
        const btn = row.querySelector(".js-stop-btn");
        const has = e.target.value.trim() !== "";
        btn.disabled = !has;
        btn.style.background = has ? "#ef4444" : "#d1d5db";
        btn.style.cursor = has ? "pointer" : "not-allowed";
      }
    });

    jsBody.addEventListener("click", (e) => {
      const startBtn = e.target.closest(".js-start-btn");
      if (startBtn && !startBtn.disabled) {
        const row = startBtn.closest("tr");
        const time = nowHHMM();
        row.querySelector(".js-start-input").value = time;
        row.querySelector(".js-start-display").textContent = time;
        startBtn.disabled = true;
        startBtn.innerHTML = '<i class="fa-solid fa-check"></i>';
        startBtn.style.background = "#6b7280";
        startBtn.style.cursor = "default";
        return;
      }
      const stopBtn = e.target.closest(".js-stop-btn");
      if (stopBtn && !stopBtn.disabled) {
        const row = stopBtn.closest("tr");
        const time = nowHHMM();
        row.querySelector(".js-stop-input").value = time;
        row.querySelector(".js-stop-display").textContent = time;
        stopBtn.disabled = true;
        stopBtn.innerHTML = '<i class="fa-solid fa-check"></i>';
        stopBtn.style.background = "#6b7280";
        stopBtn.style.cursor = "default";
      }
    });

    jsPlus.addEventListener("click", () => { jsBody.appendChild(createJsRow()); jsRenumber(); });
    jsMinus.addEventListener("click", () => { if (jsBody.rows.length > 1) { jsBody.removeChild(jsBody.lastElementChild); jsRenumber(); } });
    jsBody.appendChild(createJsRow());
    jsRenumber();

    /* ── Production Log dynamic rows ── */
    const logBody   = document.getElementById("logTableBody");
    const logCount  = document.getElementById("logCount");
    const logPlus   = document.getElementById("logPlus");
    const logMinus  = document.getElementById("logMinus");

    function renumber() {
      Array.from(logBody.rows).forEach((row, i) => {
        row.cells[0].textContent = i + 1;
      });
      logCount.value = logBody.rows.length;
    }

    const jointOptionHtml = `
      <option value="" selected hidden>—</option>
      <option value="Joint">Joint</option>
      <option value="Wrinkle">Wrinkle</option>`;

    function createLogRow() {
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td style="text-align:center; font-weight:600; color:#03365a; background:#f0f7ff;"></td>
        <td><input type="text" name="deckleId" class="form-control" placeholder="Deckle ID" /></td>
        <td style="text-align:center; font-size:12px; font-weight:700; color:#03365a; white-space:nowrap; min-width:52px;">
          <span class="start-display" style="color:#03365a;">—</span>
          <input type="hidden" name="startTime" class="start-time-input" />
        </td>
        <td style="text-align:center; font-size:12px; font-weight:700; white-space:nowrap; min-width:52px;">
          <span class="end-display" style="color:#dc2626;">—</span>
          <input type="hidden" name="endTime" class="end-time-input" />
        </td>
        <td style="text-align:center; white-space:nowrap;">
          <button type="button" class="timer-btn" data-state="idle"
            style="width:32px; height:26px; padding:0; font-size:12px; border:none; border-radius:4px; cursor:pointer; background:#10b981; color:white; display:inline-flex; align-items:center; justify-content:center; flex-shrink:0;">
            <i class="fa-solid fa-play"></i>
          </button>
        </td>
        <td><input type="number" name="logMeters"    class="form-control" placeholder="Meters" min="0" step="any" /></td>
        <td><select name="faceJoint"    class="form-control" style="padding:6px 8px !important; font-size:13px !important; height:auto !important; min-width:100px;">${jointOptionHtml}</select></td>
        <td><input type="number" name="faceMtr"      class="form-control" placeholder="Mtr" min="0" step="any" /></td>
        <td><select name="releaseJoint" class="form-control" style="padding:6px 8px !important; font-size:13px !important; height:auto !important; min-width:100px;">${jointOptionHtml}</select></td>
        <td><input type="number" name="releaseMtr"   class="form-control" placeholder="Mtr" min="0" step="any" /></td>`;
      return tr;
    }

    function nowHHMM() {
      const d = new Date();
      let h = d.getHours();
      const m = String(d.getMinutes()).padStart(2,"0");
      const ampm = h >= 12 ? "PM" : "AM";
      h = h % 12 || 12;
      return `${h}:${m} ${ampm}`;
    }

    logBody.addEventListener("click", (e) => {
      const btn = e.target.closest(".timer-btn");
      if (!btn) return;
      const row   = btn.closest("tr");
      const state = btn.dataset.state;
      const time  = nowHHMM();

      if (state === "idle") {
        row.querySelector(".start-time-input").value = time;
        row.querySelector(".start-display").textContent = time;
        btn.dataset.state = "running";
        btn.innerHTML = '<i class="fa-solid fa-stop"></i>';
        btn.style.background = "#ef4444";
      } else if (state === "running") {
        row.querySelector(".end-time-input").value = time;
        row.querySelector(".end-display").textContent = time;
        btn.dataset.state = "done";
        btn.innerHTML = '<i class="fa-solid fa-check"></i>';
        btn.style.background = "#6b7280";
        btn.disabled = true;
        btn.style.cursor = "default";
      }
    });

    logPlus.addEventListener("click", () => {
      logBody.appendChild(createLogRow());
      renumber();
    });

    logMinus.addEventListener("click", () => {
      if (logBody.rows.length > 1) {
        logBody.removeChild(logBody.lastElementChild);
        renumber();
      }
    });

    logBody.appendChild(createLogRow());
    renumber();
  });
</script>
