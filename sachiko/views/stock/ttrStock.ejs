<% layout('/layout/boilerplate') -%>

<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
  <form class="rottary-content" method="post" action="/fairdesk/ttrstock/create">

    <!-- ================= HEADER ================= -->
    <div class="span-full form-heading" style="display:flex; justify-content:space-between; flex-direction:row;">
      <!-- ================= TITLE ================= -->
      <h1>TTR Stock Entry</h1>
    </div>

    <input type="hidden" name="location" id="locationInput" />
    <div id="stock-display" class="span-full" style="display:flex; padding: 10px 15px; background: #fff; border: 1px solid #044A78; border-radius: 0.5rem; transition: all 0.3s ease; align-items: center; gap: 16px; overflow-x: auto; white-space: nowrap;"></div>

    <!-- ================= TTR SPECS ================= -->
    <div class="span-full form-subheading" style="display:flex; justify-content:space-between; align-items:center;">
      <h1>TTR Specifications</h1>
      <button type="button" id="resetBtn" style="padding: 4px 12px; border-radius: 4px; background-color: #dc3545; color: white; border: none; cursor: pointer; font-size: 14px;">Reset</button>
    </div>

    <div class="span-five">
      <label>TTR ID</label>
      <input type="text" id="resolvedTtr" class="form-control input-tag" placeholder="ID will appear here" readonly />
      <input type="hidden" name="ttrId" id="resolvedTtrId" />
    </div>

    <div class="span-seven">
      <label for="ttr-material-code">FS Code</label>
      <select name="ttrMaterialCode" id="ttr-material-code" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% materialCodes?.forEach(mc => { %>
          <option value="<%= mc %>"><%= mc %></option>
        <% }) %>
      </select>
    </div>
    <div class="span-five">
      <label for="ttr-type">FS Type</label>
      <select name="ttrType" id="ttr-type" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% types?.forEach(t => { %>
          <option value="<%= t %>"><%= t %></option>
        <% }) %>
      </select>
    </div>
    <div class="span-five">
      <label for="ttr-color">Color</label>
      <select name="ttrColor" id="ttr-color" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% colors?.forEach(c => { %>
          <option value="<%= c %>"><%= c %></option>
        <% }) %>
      </select>
    </div>
    <div class="span-five">
      <label for="ttr-width">Width</label>
      <select name="ttrWidth" id="ttr-width" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% widths?.forEach(w => { %>
          <option value="<%= w %>"><%= w %></option>
        <% }) %>
      </select>
    </div>
    <div class="span-five">
      <label for="ttr-mtrs">MTRS</label>
      <select name="ttrMtrs" id="ttr-mtrs" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% mtrsList?.forEach(m => { %>
          <option value="<%= m %>"><%= m %></option>
        <% }) %>
      </select>
    </div>
    <div class="span-seven">
      <label for="ttr-ink-face">Ink Face</label>
      <select name="ttrInkFace" id="ttr-ink-face" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% inkFaces?.forEach(i => { %>
          <option value="<%= i %>"><%= i %></option>
        <% }) %>
      </select>
    </div>
    <div class="span-six">
      <label for="ttr-core-id">Core ID</label>
      <select name="ttrCoreId" id="ttr-core-id" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% coreIds?.forEach(c => { %>
          <option value="<%= c %>"><%= c %></option>
        <% }) %>
      </select>
    </div>
    <div class="span-six">
      <label for="ttr-core-length">Core Length</label>
      <select name="ttrCoreLength" id="ttr-core-length" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% coreLengths?.forEach(cl => { %>
          <option value="<%= cl %>"><%= cl %></option>
        <% }) %>
      </select>
    </div>
    <div class="span-six">
      <label for="ttr-notch">Notch</label>
      <select name="ttrNotch" id="ttr-notch" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% notches?.forEach(n => { %>
          <option value="<%= n %>"><%= n %></option>
        <% }) %>
      </select>
    </div>
    <div class="span-seven">
      <label for="ttr-winding">Winding</label>
      <select name="ttrWinding" id="ttr-winding" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% windings?.forEach(w => { %>
          <option value="<%= w %>"><%= w %></option>
        <% }) %>
      </select>
    </div>

    <!-- ================= RESOLVED TTR ================= -->
    <div class="span-full form-subheading"></div>

    <!-- ================= QUANTITY ================= -->
    <div class="span-seven">
      <label>Quantity</label>
      <input type="number" name="quantity" class="form-control input-tag" min="1" placeholder="Enter Quantity" required />
    </div>

    <div class="span-four">
      <label>Date</label>
      <input type="date" id="stock-date" name="date" class="form-control input-tag" required />
    </div>

    <div class="span-half" style="grid-column: span 21;">
      <label>Remarks</label>
      <input type="text" name="remarks" class="form-control input-tag" placeholder="Enter Remarks" />
    </div>

    <div class="span-full btn-grp">
      <button type="submit" id="submitBtn" disabled>Save Stock</button>
    </div>

  </form>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const locationInput = document.getElementById("locationInput");
  const stockDisplay = document.getElementById("stock-display");
  const allLocations = <%- safeJson(locations || []) %>;
  const stockDateInput = document.getElementById("stock-date");

  if (stockDateInput) {
    const today = new Date();
    const yyyy = today.getFullYear();
    const mm = String(today.getMonth() + 1).padStart(2, "0");
    const dd = String(today.getDate()).padStart(2, "0");
    stockDateInput.value = `${yyyy}-${mm}-${dd}`;
  }

  const resolvedTtr = document.getElementById("resolvedTtr");
  const resolvedTtrId = document.getElementById("resolvedTtrId");
  const submitBtn = document.getElementById("submitBtn");

  const ttrFields = [
    "ttr-type",
    "ttr-color",
    "ttr-material-code",
    "ttr-width",
    "ttr-mtrs",
    "ttr-ink-face",
    "ttr-core-id",
    "ttr-core-length",
    "ttr-notch",
    "ttr-winding",
  ];

  /* ================= CONFIG ================= */
  const fieldToApiKey = {
    "ttr-type": "types",
    "ttr-color": "colors",
    "ttr-material-code": "materialCodes",
    "ttr-width": "widths",
    "ttr-mtrs": "mtrsList",
    "ttr-ink-face": "inkFaces",
    "ttr-core-id": "coreIds",
    "ttr-core-length": "coreLengths",
    "ttr-notch": "notches",
    "ttr-winding": "windings",
  };

  const fieldToParam = {
    "ttr-type": "ttrType",
    "ttr-color": "ttrColor",
    "ttr-material-code": "ttrMaterialCode",
    "ttr-width": "ttrWidth",
    "ttr-mtrs": "ttrMtrs",
    "ttr-ink-face": "ttrInkFace",
    "ttr-core-id": "ttrCoreId",
    "ttr-core-length": "ttrCoreLength",
    "ttr-notch": "ttrNotch",
    "ttr-winding": "ttrWinding",
  };

  /* ================= CHOICES INIT ================= */
  const specChoices = {};
  ttrFields.forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      specChoices[id] = new Choices(el, {
        searchEnabled: true,
        shouldSort: false,
        itemSelectText: "",
      });
    }
  });

  const initialOptions = {
    "ttr-type": <%- safeJson(types || []) %>,
    "ttr-color": <%- safeJson(colors || []) %>,
    "ttr-material-code": <%- safeJson(materialCodes || []) %>,
    "ttr-width": <%- safeJson(widths || []) %>,
    "ttr-mtrs": <%- safeJson(mtrsList || []) %>,
    "ttr-ink-face": <%- safeJson(inkFaces || []) %>,
    "ttr-core-id": <%- safeJson(coreIds || []) %>,
    "ttr-core-length": <%- safeJson(coreLengths || []) %>,
    "ttr-notch": <%- safeJson(notches || []) %>,
    "ttr-winding": <%- safeJson(windings || []) %>,
  };

  /* ================= SMART FILTER ================= */
  async function filterSpecs(changedFieldId) {
    const params = new URLSearchParams();
    ttrFields.forEach(id => {
      const el = document.getElementById(id);
      if (el && el.value) {
        params.set(fieldToParam[id], el.value);
      }
    });

    try {
      const res = await fetch(`/fairdesk/ttrstock/filter-specs?${params}`);
      const data = await res.json();
      if (!data) return;

      const autoSelected = [];

      ttrFields.forEach(id => {
        if (id === changedFieldId) return; // skip the field that triggered the filter
        const choicesInstance = specChoices[id];
        if (!choicesInstance) return;

        const apiKey = fieldToApiKey[id];
        const filteredValues = data[apiKey] || [];
        const currentValue = document.getElementById(id)?.value || "";

        const values = filteredValues.slice();
        const hasCurrent = currentValue && values.some(v => String(v) === String(currentValue));
        if (currentValue && !hasCurrent) values.unshift(currentValue);

        const newChoices = values.map(v => ({
          value: String(v),
          label: String(v),
          selected: String(v) === currentValue,
        }));

        // Auto-select if exactly one option and nothing currently selected
        if (filteredValues.length === 1 && !currentValue) {
          newChoices[0].selected = true;
          autoSelected.push(id);
        }

        choicesInstance.clearStore();
        choicesInstance.setChoices(
          [{ value: "", label: "Search", disabled: true, selected: !newChoices.some(c => c.selected) }, ...newChoices],
          "value",
          "label",
          true
        );
      });

      // If any fields were auto-selected, re-run filter to cascade
      if (autoSelected.length > 0) {
        await filterSpecs(autoSelected[0]);
        resolveTtr();
      }
    } catch (err) {
      console.error("Filter specs error:", err);
    }
  }

  /* ================= RESOLVE ================= */
  async function resolveTtr() {
    const values = {};
    for (let id of ttrFields) {
      const el = document.getElementById(id);
      if (!el || !el.value) return;
      values[id] = el.value;
    }

    const res = await fetch("/fairdesk/ttrstock/resolve", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        type: values["ttr-type"],
        color: values["ttr-color"],
        materialCode: values["ttr-material-code"],
        width: values["ttr-width"],
        mtrs: values["ttr-mtrs"],
        inkFace: values["ttr-ink-face"],
        coreId: values["ttr-core-id"],
        coreLength: values["ttr-core-length"],
        notch: values["ttr-notch"],
        winding: values["ttr-winding"],
      })
    });

    const data = await res.json();

    if (!data.found) {
      resolvedTtr.value = "No matching TTR found";
      resolvedTtrId.value = "";
      locationInput.value = "";
      renderStockDisplay({}, normalizeLocationName(locationInput.value || ""));
      submitBtn.disabled = true;
      return;
    }

    resolvedTtr.value = data.TtrProductId || "";
    resolvedTtrId.value = data.ttrId;
    submitBtn.disabled = false;

    await updateStockDisplay();
  }

  function normalizeLocationName(value) {
    return String(value || "")
      .trim()
      .toUpperCase()
      .replace(/\s+/g, " ")
      .replace(/^[.,]+|[.,]+$/g, "");
  }

  function selectStockLocation(locationName) {
    const normalizedLocation = normalizeLocationName(locationName);
    const radio = stockDisplay?.querySelector(`input[name="locationRadio"][value="${normalizedLocation}"]`);

    stockDisplay?.querySelectorAll(".location-option").forEach((option) => {
      option.classList.remove("selected");
    });

    if (!normalizedLocation) {
      locationInput.value = "";
      return false;
    }

    if (!radio) {
      locationInput.value = "";
      return false;
    }

    radio.checked = true;
    const row = radio.closest(".location-option");
    if (row) row.classList.add("selected");
    locationInput.value = normalizedLocation;
    return true;
  }

  function renderStockDisplay({ totalStock = "-", booked = "-", balance = "-", locations = [] } = {}, selectedLocation = "") {
    const locationRows = (locations.length ? locations : allLocations.map((loc) => ({ location: loc }))).map((loc) => {
      const locationName = normalizeLocationName(loc.location);
      const qty = loc.qty ?? loc.balance ?? "-";
      const isSelected = selectedLocation && locationName === selectedLocation;

      return `<label class="location-option${isSelected ? " selected" : ""}" data-location="${locationName}" data-qty="${qty}" data-booked="${loc.booked ?? "-"}" data-balance="${loc.balance ?? qty}">
        <input type="radio" name="locationRadio" class="location-radio" value="${locationName}" data-qty="${qty}" data-booked="${loc.booked ?? "-"}" data-balance="${loc.balance ?? qty}" ${isSelected ? "checked" : ""} />
        <span class="location-label">${locationName}:</span>
        <span class="location-qty">${loc.balance ?? qty}</span>
      </label>`;
    }).join("");

    stockDisplay.innerHTML = `
      <div style="display: flex; align-items: center; justify-content: space-between; gap: 22px; flex-wrap: nowrap; white-space: nowrap; width: 100%;">
        <div style="display: inline-flex; flex-wrap: nowrap; align-items: center; white-space: nowrap;">
          ${locationRows}
        </div>
        <div id="stock-stats" style="display: inline-flex; gap: 14px; align-items: center; flex-wrap: nowrap; white-space: nowrap;">
          <div style="font-weight: 700; color: #044A78; font-size: 16px;">
            <i class="fa-solid fa-box-open"></i> Total: <span id="stat-total">${totalStock}</span>
          </div>
          <div style="font-weight: 700; color: #d97706; font-size: 16px;" title="Booked stock">
            <i class="fa-regular fa-clock"></i> Booked: <span id="stat-booked">${booked}</span>
          </div>
          <div style="font-weight: 700; color: #059669; font-size: 16px;" title="Available balance">
            <i class="fa-solid fa-scale-balanced"></i> Balance: <span id="stat-balance">${balance}</span>
          </div>
        </div>
      </div>
    `;
    stockDisplay.style.display = "flex";

    stockDisplay.querySelectorAll('input[name="locationRadio"]').forEach((radio) => {
      radio.addEventListener("change", () => {
        selectStockLocation(radio.value);
      });
    });
  }

  async function updateStockDisplay() {
    if (!resolvedTtrId.value) {
      renderStockDisplay({}, normalizeLocationName(locationInput.value || ""));
      return;
    }

    try {
      const res = await fetch(`/fairdesk/ttrstock/stock-info/${resolvedTtrId.value}`);
      const data = await res.json();
      const locations = Array.isArray(data?.locations) ? data.locations : [];
      const preferredLocation = normalizeLocationName(locationInput.value || "");
      const hasPreferred = preferredLocation && locations.some((loc) => normalizeLocationName(loc.location) === preferredLocation);
      const selectedLocation = hasPreferred ? preferredLocation : normalizeLocationName(locations[0]?.location || "");
      renderStockDisplay(data, selectedLocation);
      if (selectedLocation) {
        selectStockLocation(selectedLocation);
      } else {
        locationInput.value = "";
      }
    } catch (err) {
      console.error("Failed to load stock display", err);
      renderStockDisplay({}, normalizeLocationName(locationInput.value || ""));
    }
  }

  /* ================= HANDLERS ================= */
  const resetBtn = document.getElementById("resetBtn");
  if (resetBtn) {
    resetBtn.addEventListener("click", () => {
      ttrFields.forEach(id => {
        const choicesInstance = specChoices[id];
        if (!choicesInstance) return;
        const values = initialOptions[id] || [];
        const newChoices = values.map(v => ({
          value: String(v),
          label: String(v),
        }));
        choicesInstance.clearStore();
        choicesInstance.setChoices(
          [{ value: "", label: "Search", disabled: true, selected: true }, ...newChoices],
          "value",
          "label",
          true
        );
      });

      resolvedTtr.value = "";
      resolvedTtrId.value = "";
      locationInput.value = "";
      renderStockDisplay({}, "");
      submitBtn.disabled = true;
    });
  }

  ttrFields.forEach(id => {
    document.getElementById(id)?.addEventListener("change", async () => {
      await filterSpecs(id);
      resolveTtr();
    });
  });

  stockDisplay.addEventListener("change", (event) => {
    const radio = event.target.closest?.('input[name="locationRadio"]');
    if (!radio) return;
    selectStockLocation(radio.value);
  });

  document.querySelector("form")?.addEventListener("submit", (event) => {
    if (!locationInput.value) {
      event.preventDefault();
      alert("Please select a location.");
    }
  });

  renderStockDisplay({}, "");
});
</script>

<style>
  .location-option {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-right: 5px;
    cursor: pointer;
    padding: 5px 8px;
    border-radius: 0.4rem;
    border: 2px solid transparent;
    transition: all 0.2s ease;
    user-select: none;
  }

  .location-option:hover {
    background: #f0f0ff;
  }

  .location-option.selected {
    border-color: #044A78;
    background: #eef0ff;
  }

  .location-radio {
    accent-color: #044A78;
    width: 16px;
    height: 16px;
    cursor: pointer;
    border-radius: 999px;
  }

  .location-label {
    color: #044A78;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
  }

  .location-qty {
    font-weight: 700;
    color: #044A78;
    font-size: 15px;
  }
</style>
