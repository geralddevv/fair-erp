<% layout('/layout/boilerplate') -%>

<!-- ================= TABULATOR CSS ================= -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />

<style>
  .loan-highlight {
    padding: 0.25rem 0.6rem;
    border-radius: 0.35rem;
    font-weight: 600;
    font-size: 1.15rem;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.5);
    background-color: rgba(255, 255, 255, 0.12);
  }

  .loan-highlight.active {
    background-color: rgba(255, 255, 255, 0.16);
  }
  .loan-highlight.closed {
    background-color: rgba(40, 167, 69, 0.25);
    border-color: rgba(40, 167, 69, 0.8);
  }

  #master-table {
    width: 100%;
    flex: 1 1 auto;
    min-height: 0;
  }
</style>

<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
  <div class="indi-head" style="padding: 12px 14px; display: flex; justify-content: space-between; align-items: center">
    <span style="display: flex; align-items: center; gap: 15px">
      <h1 id="advanceHeading">
        Advance — <span style="color: inherit; font-weight: 600"><%= employee.empName %></span>
        <span class="loan-highlight <%= summary.status.toLowerCase() %>" style="margin-left: 8px">
          Outstanding: Rs.<%= summary.currentBalance.toLocaleString('en-IN') %>
        </span>
      </h1>
    </span>

    <div class="download-btns" style="display: flex; gap: 10px; align-items: center">
      <div class="download-selector" id="downloadSelector">
        <button class="download-selector__trigger">
          <span> <i class="fa-solid fa-file-arrow-down"></i> Download </span>
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="download-selector__menu">
          <div class="download-selector__option" id="download-pdf"><i class="fas fa-file-pdf"></i> PDF</div>
          <div class="download-selector__option" id="download-xlsx"><i class="fas fa-file-excel"></i> Excel</div>
        </div>
      </div>
    </div>
  </div>

  <div class="table-spinner"><div class="spinner-circle"></div></div>
  <div id="master-table"></div>
</div>

<!-- Edit/Delete Dialogs (Same as main view) -->
<div
  id="advance-edit-dialog"
  style="
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(17, 24, 39, 0.55);
    z-index: 9999;
    align-items: center;
    justify-content: center;
  "
>
  <div
    style="
      background: #fff;
      width: 460px;
      max-width: 92vw;
      border-radius: 14px;
      padding: 20px 22px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
    "
  >
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px">
      <h3 style="margin: 0; color: #0f172a; font-size: 18px">
        <i class="fa-solid fa-pen-to-square" style="margin-right: 6px; color: #2563eb"></i>Edit Advance Entry
      </h3>
      <button
        type="button"
        onclick="closeAdvanceEditDialog()"
        style="border: none; background: transparent; color: #6b7280; font-size: 18px; cursor: pointer"
      >
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <input type="hidden" id="advance-edit-id" />
    <div style="margin-bottom: 14px">
      <label style="font-size: 12px; color: #6b7280; font-weight: 600">Amount</label>
      <input
        type="number"
        id="advance-edit-amount"
        min="1"
        style="
          width: 100%;
          height: 42px;
          padding: 10px 12px;
          border: 1px solid #cbd5e1;
          border-radius: 8px;
          background: #ffffff;
          color: #0f172a;
          font-size: 14px;
        "
      />
    </div>
    <div style="display: flex; justify-content: flex-end; gap: 10px">
      <button
        type="button"
        onclick="closeAdvanceEditDialog()"
        style="
          padding: 9px 16px;
          border: 1px solid #e2e8f0;
          background: white;
          color: #334155;
          border-radius: 8px;
          cursor: pointer;
        "
      >
        Cancel
      </button>
      <button
        type="button"
        onclick="submitAdvanceEdit()"
        style="padding: 9px 16px; border: none; background: #044a78; color: white; border-radius: 8px; cursor: pointer"
      >
        Save Changes
      </button>
    </div>
  </div>
</div>

<div
  id="advance-delete-dialog"
  style="
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 9999;
    align-items: center;
    justify-content: center;
  "
>
  <div style="background: #fff; width: 430px; max-width: 92vw; border-radius: 10px; padding: 18px 20px">
    <h3 style="margin: 0 0 10px; color: #b91c1c; font-size: 17px">
      <i class="fa-solid fa-triangle-exclamation" style="margin-right: 6px"></i>Delete Advance Entry
    </h3>
    <p style="margin: 0 0 14px; color: #374151">Are you sure you want to delete this manual advance entry?</p>
    <input type="hidden" id="advance-delete-id" />
    <div style="display: flex; justify-content: flex-end; gap: 10px">
      <button
        type="button"
        onclick="closeAdvanceDeleteDialog()"
        style="
          padding: 8px 16px;
          border: 1px solid #d1d5db;
          background: white;
          color: #374151;
          border-radius: 6px;
          cursor: pointer;
        "
      >
        Cancel
      </button>
      <button
        type="button"
        onclick="submitAdvanceDelete()"
        style="padding: 8px 16px; border: none; background: #ef4444; color: white; border-radius: 6px; cursor: pointer"
      >
        Yes, Delete
      </button>
    </div>
  </div>
</div>

<!-- ================= SCRIPTS ================= -->
<script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.4.0/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.20/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/file-saver@2.0.5/dist/FileSaver.min.js"></script>

<script>
  const logs = <%- safeJson(logs) %>;
  const currentEmployeeId = '<%= employee._id %>';

  function formatINRCurrency(value) {
    return new Intl.NumberFormat("en-IN", {
      style: "currency",
      currency: "INR",
      minimumFractionDigits: 0,
    }).format(Number(value) || 0);
  }

  const columns = [
    { title: "Date", field: "date" },
    { title: "Time", field: "time" },
    { title: "Type", field: "type", formatter: (c) => `<span style="font-weight:600; color:${c.getValue()==='CREDIT'?'#059669':'#dc2626'}">${c.getValue()}</span>`, htmlOutput: true },
    { title: "Opening Balance", field: "openingBalance", formatter: (c) => formatINRCurrency(c.getValue()) },
    { title: "Amount", field: "amount", formatter: (c) => formatINRCurrency(c.getValue()) },
    { title: "Closing Balance", field: "closingBalance", formatter: (c) => formatINRCurrency(c.getValue()) },
    { title: "Source", field: "source" },
    {
      title: "Actions",
      width: 90,
      hozAlign: "center",
      headerSort: false,
      formatter: (cell) => {
        const row = cell.getRow().getData();
        if (!row.canEdit) return "-";
        return `<button class="advance-log-btn advance-log-edit" title="Edit" style="height:20px; width:28px; padding:0; margin-right:6px; border:1px solid #d1d5db; background:#fff; border-radius:4px; cursor:pointer; line-height:1;"><i class="fa-solid fa-pen-to-square" style="font-size:11px; color:#044A78;"></i></button>
                <button class="advance-log-btn advance-log-delete" title="Delete" style="height:20px; width:28px; padding:0; border:1px solid #fca5a5; background:#fee2e2; border-radius:4px; cursor:pointer; line-height:1;"><i class="fa-solid fa-trash" style="font-size:11px; color:#b91c1c;"></i></button>`;
      },
      cellClick: (e, cell) => {
        const row = cell.getRow().getData();
        if (!row.canEdit) return;
        if (e.target.closest(".advance-log-edit")) openAdvanceEditDialog(row);
        if (e.target.closest(".advance-log-delete")) openAdvanceDeleteDialog(row);
      }
    }
  ];

  const table = new Tabulator("#master-table", {
    data: logs,
    height: "100%",
    // layout: "fitColumns",
    columns: columns,
  });

  /* Download Dropdown Logic */
  const downloadSelector = document.getElementById("downloadSelector");
  const triggerBtn = downloadSelector.querySelector(".download-selector__trigger");
  triggerBtn.addEventListener("click", (e) => {
    e.stopPropagation();
    downloadSelector.classList.toggle("download-selector--active");
  });
  document.addEventListener("click", () => downloadSelector.classList.remove("download-selector--active"));

  document.getElementById("download-pdf").addEventListener("click", () => {
    table.download("pdf", "advance-<%= employee.empName %>-history.pdf", { orientation: "landscape", title: "Advance History - <%= employee.empName %>" });
  });
  document.getElementById("download-xlsx").addEventListener("click", () => {
    table.download("xlsx", "advance-<%= employee.empName %>-history.xlsx", { sheetName: "Advance History" });
  });

  /* Edit/Delete Functions */
  function openAdvanceEditDialog(row) {
    document.getElementById("advance-edit-id").value = row._id;
    document.getElementById("advance-edit-amount").value = row.amount;
    document.getElementById("advance-edit-dialog").style.display = "flex";
  }
  function closeAdvanceEditDialog() { document.getElementById("advance-edit-dialog").style.display = "none"; }
  function openAdvanceDeleteDialog(row) {
    document.getElementById("advance-delete-id").value = row._id;
    document.getElementById("advance-delete-dialog").style.display = "flex";
  }
  function closeAdvanceDeleteDialog() { document.getElementById("advance-delete-dialog").style.display = "none"; }

  async function submitAdvanceEdit() {
    const id = document.getElementById("advance-edit-id").value;
    const amount = Number(document.getElementById("advance-edit-amount").value);
    if (!id || amount <= 0) return alert("Invalid amount");
    const res = await fetch(`/fairdesk/advance/logs/${id}`, { method: "PATCH", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ amount }) });
    if (res.ok) window.location.reload();
    else alert("Update failed");
  }

  async function submitAdvanceDelete() {
    const id = document.getElementById("advance-delete-id").value;
    if (!id) return;
    const res = await fetch(`/fairdesk/advance/logs/${id}`, { method: "DELETE" });
    if (res.ok) window.location.reload();
    else alert("Delete failed");
  }
</script>
