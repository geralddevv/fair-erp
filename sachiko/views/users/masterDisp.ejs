<!-- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>
<!-- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>

<!-- Tabulator CSS -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />

<body>
  <div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
    <style>
      .header-action-btn {
        background-color: #f0f0f0;
        color: #044a78;
        padding: 2px 14px; /* Matches Download button padding exactly */
        font-size: 14px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        border-radius: 0.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transition: all 0.2s ease-in-out;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .header-action-btn:hover {
        background-color: #e4e4e4;
      }
      .col-count-center .tabulator-col-content {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        justify-content: center;
        gap: 3px;
        padding: 4px 2px 6px;
      }
      .tabulator .tabulator-header .tabulator-col.col-count-center {
        justify-content: center;
      }
      .col-count-center .tabulator-col-title-holder {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: auto;
        width: 100%;
      }
      .col-count-center .tabulator-col-title {
        width: 100%;
        text-align: center;
        white-space: nowrap;
        line-height: 1.1;
      }
      .col-count-center .tabulator-header-filter {
        width: 100%;
        margin-top: 0;
      }
      .col-count-center .tabulator-header-filter input {
        width: 100%;
        box-sizing: border-box;
      }
      .tabulator-cell.col-count-center {
        text-align: center;
        vertical-align: middle;
      }
      #master-table {
        width: 100%;
        flex: 1 1 auto;
        min-height: 0;
      }
      #master-table .tabulator-row.row-missing-details .tabulator-cell {
        background-color: #d9534f !important;
        color: #ffffff !important;
      }
      #master-table .tabulator-row.row-missing-details:hover .tabulator-cell {
        background-color: #c9302c !important;
        color: #ffffff !important;
      }
    </style>

    <div class="indi-head">
      <h1>Client Details</h1>

      <div style="display: flex; gap: 10px; align-items: center">
        <button class="header-action-btn" onclick="window.location.href = '/fairdesk/form/client?tab=user'">
          <i class="fa-solid fa-plus" style="margin-right: 4px"></i> User
        </button>
        <button class="header-action-btn" onclick="window.location.href = '/fairdesk/form/client?tab=client'">
          <i class="fa-solid fa-plus" style="margin-right: 4px"></i> Client
        </button>

        <div class="download-selector" id="downloadSelector">
          <button class="download-selector__trigger">
            <span>
              <i class="fa-solid fa-file-arrow-down"></i>
              <span class="download-typo">Download</span>
            </span>
            <i class="fas fa-chevron-down download-selector__trigger-icon"></i>
          </button>
          <div class="download-selector__menu" id="downloads">
            <span class="download-selector__option" id="download-pdf">
              <i class="fas fa-file-pdf download-selector__option-icon"></i>
              <span>PDF</span>
            </span>
            <span class="download-selector__option" id="download-xlsx">
              <i class="fas fa-file-excel download-selector__option-icon"></i>
              <span>Excel</span>
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="table-spinner"><div class="spinner-circle"></div></div>
    <div id="master-table" class="tabulator tabulator-modern"></div>
  </div>

  <!-- Tabulator JS -->
  <script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.4.0/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.20/jspdf.plugin.autotable.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/file-saver@2.0.5/dist/FileSaver.min.js"></script>

  <script>
    // ================= DOWNLOAD DROPDOWN UI =================

    const downloadSelector = document.getElementById("downloadSelector");
    const triggerBtn = downloadSelector.querySelector(".download-selector__trigger");

    // Toggle dropdown
    triggerBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      downloadSelector.classList.toggle("download-selector--active");

      const icon = triggerBtn.querySelector(".download-selector__trigger-icon");
      icon.style.transform = downloadSelector.classList.contains("download-selector--active")
        ? "rotate(180deg)"
        : "rotate(0deg)";
    });

    // Close dropdown when clicking outside
    document.addEventListener("click", () => {
      downloadSelector.classList.remove("download-selector--active");
      const icon = triggerBtn.querySelector(".download-selector__trigger-icon");
      icon.style.transform = "rotate(0deg)";
    });

    // Prevent close when clicking inside dropdown
    downloadSelector.querySelector(".download-selector__menu").addEventListener("click", (e) => {
      e.stopPropagation();
    });

    // ================= TABULATOR DATA =================

    // Render data from Express (passed into EJS)
    let tableData = [];
    try {
      tableData = <%- safeJson(jsonData || []) %>;
      console.log(tableData);
    } catch (err) {
      console.error("Master Disp JSON error", err);
    }

    tableData.forEach((user) => {
      user.labelCount = user.labelCount ?? 0;
      user.ttrCount = user.ttr?.length || 0;
      user.tapeCount = user.tape?.length || 0;
      user.posRollCount = user.posRoll?.length || 0;
      user.tafetaCount = user.tafeta?.length || 0;
      user.dispatchType = user.SelfDispatch ? "Self Dispatch" : "Transport";
    });

    // ================= TABULATOR INIT =================

    let table; // MUST be global for download to work
    const requiredFields = ["clientName", "clientType", "accountHead", "userName", "userLocation"];

    const withTextFilter = (column, placeholder = "Search") => ({
      headerFilter: "input",
      headerFilterPlaceholder: placeholder,
      minWidth: 100,
      ...column,
    });

    function hasMissingDetails(row) {
      return requiredFields.some((field) => {
        const value = row?.[field];
        return value === undefined || value === null || String(value).trim() === "";
      });
    }

    function initTable() {
      table = new Tabulator("#master-table", {
        data: tableData,
        height: "100%",
        // layout: "fitColumns",
        virtualDom: true,
        responsiveLayout: false,
        initialSort: [{ column: "clientName", dir: "asc" }],
        movableColumns: true,
        placeholder: "No data to display",
        rowFormatter: (row) => {
          const rowEl = row.getElement();
          if (hasMissingDetails(row.getData())) {
            rowEl.classList.add("row-missing-details");
          } else {
            rowEl.classList.remove("row-missing-details");
          }
        },
        columns: [
          withTextFilter({
            title: "Name",
            field: "clientName",
            headerSort: true,
            widthGrow: 2,
          }),
          withTextFilter({
            title: "Type",
            field: "clientType",
            headerSort: true,
            width: 100,
          }),
          withTextFilter({
            title: "Account Head",
            field: "accountHead",
            headerSort: true,
            widthGrow: 2,
          }),
          withTextFilter({
            title: "User Name",
            field: "userName",
            formatter: (cell) => {
              return `
              <span style="cursor:pointer;font-weight:600;text-decoration:underline;">
                ${cell.getValue()}
              </span>
            `;
            },
            cellClick: (e, cell) => {
              const row = cell.getRow().getData();
              window.location.href = `/fairdesk/client/details/${row._id}`;
            },
            headerSort: true,
            widthGrow: 2,
          }),
          withTextFilter({
            title: "Location",
            field: "userLocation",
            headerSort: true,
            widthGrow: 2,
          }),
          withTextFilter({
            title: "Labels",
            field: "labelCount",
            width: 95,
            widthGrow: 0,
            widthShrink: 0,
            hozAlign: "center",
            headerSort: true,
            headerSortStartingDir: "desc",
            cssClass: "col-count-center",
            formatter: (cell) => {
              const row = cell.getRow().getData();
              if (!row.labelCount) return "";
              return `<span style="cursor:pointer;text-decoration:underline;">${row.labelCount}</span>`;
            },
            cellClick: (e, cell) => {
              const row = cell.getRow().getData();
              window.location.href = `/fairdesk/labels/view/${row._id}`;
            },
          }),
          withTextFilter({
            title: "TTR's",
            field: "ttrCount",
            width: 95,
            widthGrow: 0,
            widthShrink: 0,
            hozAlign: "center",
            headerSort: true,
            headerSortStartingDir: "desc",
            cssClass: "col-count-center",
            formatter: (cell) => {
              const row = cell.getRow().getData();
              if (!row.ttrCount) return "";
              return `<span style="cursor:pointer;text-decoration:underline;">${row.ttrCount}</span>`;
            },
            cellClick: (e, cell) => {
              const row = cell.getRow().getData();
              window.location.href = `/fairdesk/ttr/view/${row._id}`;
            },
          }),
          withTextFilter({
            title: "Tapes",
            field: "tapeCount",
            width: 95,
            widthGrow: 0,
            widthShrink: 0,
            hozAlign: "center",
            headerSort: true,
            headerSortStartingDir: "desc",
            cssClass: "col-count-center",
            formatter: (cell) => {
              const row = cell.getRow().getData();
              if (!row.tapeCount) return "";
              return `<span style="cursor:pointer;text-decoration:underline;">${row.tapeCount}</span>`;
            },
            cellClick: (e, cell) => {
              const row = cell.getRow().getData();
              window.location.href = `/fairdesk/tape/view/${row._id}`;
            },
          }),
          withTextFilter({
            title: "POS Rolls",
            field: "posRollCount",
            width: 95,
            widthGrow: 0,
            widthShrink: 0,
            hozAlign: "center",
            headerSort: true,
            headerSortStartingDir: "desc",
            cssClass: "col-count-center",
            formatter: (cell) => {
              const row = cell.getRow().getData();
              if (!row.posRollCount) return "";
              return `<span style="cursor:pointer;text-decoration:underline;">${row.posRollCount}</span>`;
            },
            cellClick: (e, cell) => {
              const row = cell.getRow().getData();
              window.location.href = `/fairdesk/pos-roll/view/${row._id}`;
            },
          }),
          withTextFilter({
            title: "Tafeta",
            field: "tafetaCount",
            width: 95,
            widthGrow: 0,
            widthShrink: 0,
            hozAlign: "center",
            headerSort: true,
            headerSortStartingDir: "desc",
            cssClass: "col-count-center",
            formatter: (cell) => {
              const row = cell.getRow().getData();
              if (!row.tafetaCount) return "";
              return `<span style="cursor:pointer;text-decoration:underline;">${row.tafetaCount}</span>`;
            },
            cellClick: (e, cell) => {
              const row = cell.getRow().getData();
              window.location.href = `/fairdesk/tafeta/view/${row._id}`;
            },
          }),
        ],
      });
    }

    window.addEventListener("load", initTable);

    // ================= DOWNLOAD ACTIONS =================

    // PDF
    document.getElementById("download-pdf").addEventListener("click", () => {
      if (!table) return;

      table.download("pdf", "master-data.pdf", {
        orientation: "landscape",
        title: "Master Data",
      });

      downloadSelector.classList.remove("download-selector--active");
    });

    // Excel
    document.getElementById("download-xlsx").addEventListener("click", () => {
      if (!table) return;

      table.download("xlsx", "master-data.xlsx", {
        sheetName: "Master Data",
      });

      downloadSelector.classList.remove("download-selector--active");
    });
  </script>
</body>
