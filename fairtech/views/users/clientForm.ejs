<!--- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>

<style>
  .locations-headings {
    margin-bottom: 0;
    grid-column: span 32;
    background-color: #044A78;
    color: white;
    padding: 10px;
    border-radius: 5px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
  }

  .locations-headings span {
    flex: 1;
    font-size: 16px;
    font-weight: 600;
    padding-left: 15px;
  }

  .locations-details {
    grid-column: span 32;
  }

  .location-row {
    margin-bottom: 10px;
    padding: 6px;
    border-radius: 5px;
    border: 2px solid #044A78;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 8px;
    align-items: center;
  }

  .location-row input,
  .location-row textarea {
    width: 100%;
    border: 1px solid #044A78;
    height: 38px;
  }

  .location-row textarea {
    resize: none;
  }

  #username-client-type:disabled {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    background-image: none;
    background-color: #e9ecef;
  }

  #user-client-id,
  #username-ho-location,
  #username-account-head {
    background-color: #e9ecef;
  }

</style>

<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
  <div>
    <div class="span-full form-subheading gap" style="margin-bottom: 10px;">
      <div class="client-switch active">
        <h1>Create Client</h1>
      </div>
      <div class="user-switch">
        <h1>Create User</h1>
      </div>
    </div>       
    <form id="client-form" class="client-content span-full needs-validation" action="/fairdesk/form/client" method="post" autocomplete="off" novalidate>
    <div class="span-four">
      <label for="client-id">Client Id</label>
      <input type="text" value="<%= previewClientId %>" id="client-id" class="form-control input-tag" name="clientId" placeholder="Enter Client ID" readonly required />
    </div>      
    <div class="span-seven">
      <label for="client-name">Client Name</label>
      <input type="text" id="client-name" class="form-control input-tag" name="clientName" placeholder="Enter Client Name" required />
    </div>

    <div class="span-five">
      <label for="client-type">Client Type</label>
      <select name="clientType" id="client-type" class="form-control select-tag" required>
        <option value="" selected disabled hidden>Select</option>
        <option value="DEALER">DEALER</option>
        <option value="CLIENT">CLIENT</option>
      </select>
    </div>
    <div class="span-five">
      <label for="client-status">Client Status</label>
      <select name="clientStatus" id="client-status" class="form-control select-tag" required>
        <!-- <option value="" selected disabled hidden>Select</option> -->
        <option value="ACTIVE" selected>ACTIVE</option>
        <option value="INACTIVE">INACTIVE</option>
        <option value="FOLLOW UP">FOLLOW UP</option>
        <option value="BLACKLISTED">BLACKLISTED</option>
        <option value="ADVANCED">ADVANCED</option>
        <option value="OTHERS">OTHERS</option>
      </select>
    </div>

    <div class="span-five">
      <label for="ho-location">H/O Location</label>
      <input type="text" id="ho-location" class="form-control input-tag" name="hoLocation" placeholder="Enter H/O Location" required />
    </div>

    <div class="span-six">
      <label for="account-head">Account Head</label>
      <select name="accountHead" id="account-head" class="form-control select-tag" required>
        <option value="" selected disabled hidden>Select</option>
        <% (employees || []).forEach((employee) => { %>
          <option value="<%= employee.empName %>"><%= employee.empName %></option>
        <% }) %>
      </select>
    </div>

    <!-- <div class="span-seven">
      <label for="owner-name">Owner Name</label>
      <input type="text" id="owner-name" class="form-control input-tag" name="ownerName" placeholder="Enter Owner Name" />
    </div>

    <div class="span-six">
      <label for="owner-mob-no">Owner Mob. No.</label>
      <input type="text" id="owner-mob-no" class="form-control input-tag" name="ownerMobNo" placeholder="Enter Owner Mob. No." />
    </div>

    <div class="span-six">
      <label for="owner-email">Owner Email</label>
      <input type="email" id="owner-email" class="form-control" name="ownerEmail" placeholder="Enter Owner Email" />
    </div> -->

    <div class="span-dual">
      <label for="client-gst">GST</label>
      <input type="text" maxlength="15" id="client-gst" class="form-control" name="clientGst" placeholder="Enter GST" required />
    </div>

    <div class="span-dual">
      <label for="client-msme">MSME</label>
      <input type="text" maxlength="15" id="client-msme" class="form-control" name="clientMsme" placeholder="Enter MSME" required />
    </div> 
    <div class="span-dual">
      <label for="client-gumasta">Gumasta</label>
      <input type="text" id="client-gumasta" class="form-control" name="clientGumasta" placeholder="Enter GUMASTA" required />
    </div> 
    <div class="span-dual">
      <label for="client-pan">PAN</label>
      <input type="text" maxlength="10" id="client-pan" class="form-control" name="clientPan" placeholder="Enter PAN" required />
    </div> 

    <div class="span-full btn-grp">
      <button id="client-submit-btn" class="submit-btn" type="submit">Save Client Details</button>
    </div>
  </form>

  <!---------------------------------------------------------------------------------------------------------------------------------------------->
    <form id="user-form" action="/fairdesk/form/user" method="post" class="user-content span-full needs-validation" autocomplete="off" novalidate>
    <div class="span-full form-subheading">
      <h1>Client Information</h1>
    </div>
    <!-- Username -->

    <div class="span-dual">
      <label for="userform-client-name">Client Name</label>
      <select name="clientName" id="userform-client-name">
        <option value="" disabled selected hidden>Search</option>        
        <% for (client of clients) { %>
          <option value="<%= client %>"><%= client %></option>
        <% } %>
      </select>
    </div>

    <div class="span-four">
      <label for="user-client-id">Client Id</label>
      <input id="user-client-id" class="form-control input-tag" name="clientId" placeholder="Enter Client ID" readonly required />
    </div>

    <div class="span-six">
      <label for="client-name">Client Type</label>
      <select id="username-client-type" class="form-control select-tag" disabled>
        <option value="" selected disabled hidden>Select</option>
        <option value="DEALER">DEALER</option>
        <option value="CLIENT">CLIENT</option>
      </select>
      <input type="hidden" name="clientType" id="username-client-type-hidden" />
    </div>

    <div class="span-seven">
      <label for="ho-location">H/O Location</label>
      <input type="text" id="username-ho-location" class="form-control input-tag" name="hoLocation" placeholder="Enter H/O Location" readonly required />
    </div>

    <div class="span-seven">
      <label for="account-head">Account Head</label>
      <input type="text" id="username-account-head" class="form-control input-tag" name="accountHead" placeholder="Enter Account Head" readonly required />
    </div>    

    <div class="span-full form-subheading">
      <h1>Username Information</h1>
    </div>

    <div class="span-dual">
      <label for="user-name">Username</label>
      <input type="text" id="user-name" class="form-control input-tag" name="userName" placeholder="Enter Username" required />
    </div>

    <div class="span-dual">
      <label for="user-department">Department</label>
      <input type="text" id="user-department" class="form-control input-tag" name="userDepartment" placeholder="Enter Department" required />
    </div>

    <div class="span-dual">
      <label for="user-contact-no">Contact No</label>
      <input type="text" id="user-contact-no" class="form-control input-tag" name="userContact" placeholder="Enter Contact No" required />
    </div>

    <div class="span-dual">
      <label for="user-email">Email</label>
      <input type="email" id="user-email" class="form-control" name="userEmail" placeholder="Enter Email" required />
    </div>

    <div class="span-full form-subheading" style="display: flex; align-items: center; gap: 12px;">
      <h1>Location Details</h1>
      <div style="display: inline-flex; align-items: center; gap: 6px; margin-left: 10px;">
        <button type="button" id="locations-minus" style="width: 30px; height: 30px; border: 1px solid #044A78; background: white; color: #044A78; border-radius: 4px; font-size: 18px; line-height: 1; cursor: pointer;">-</button>
        <input
          type="text"
          id="locations-count"
          style="width: 56px; height: 30px; text-align: center; border: 1px solid #044A78; border-radius: 4px;"
          class="form-control"
          name="locationsCount"
          value="1"
          readonly
        />
        <button type="button" id="locations-plus" style="width: 30px; height: 30px; border: 1px solid #044A78; background: white; color: #044A78; border-radius: 4px; font-size: 18px; line-height: 1; cursor: pointer;">+</button>
      </div>
    </div>

    <div id="locations-details" class="locations-details">
      <div class="location-row">
        <input
          type="text"
          class="form-control input-tag"
          name="locationDetails[0][userLocation]"
          placeholder="Enter Location"
          aria-label="Location 1"
          required
        />
        <input
          type="text"
          class="form-control input-tag"
          name="locationDetails[0][dispatchAddress]"
          placeholder="Enter Address"
          aria-label="Address 1"
          required
        />
      </div>
    </div>

    <div class="span-full form-subheading">
      <h1>Dispatch Details</h1>
    </div>

    <div class="span-full form-subheading gap">
      <div class="hardware active">
        <h1>Transport</h1>
      </div>
      <div class="software">
        <h1>Self Dispatch</h1>
      </div>
    </div>       

    <div class="span-full hardware-options">
    <div class="span-six">
      <label for="transport-name">Name</label>
      <input type="text" id="transport-name" class="form-control input-tag" name="transportName" placeholder="Enter Transport Name" />
    </div>

    <div class="span-five">
      <label for="transport-contact">Contact</label>
      <input type="text" id="transport-contact" class="form-control input-tag" name="transportContact" placeholder="Enter Transport Contact" />
    </div>

    <div class="span-five">
      <label for="drop-location">Drop Location</label>
      <input type="text" id="drop-location" class="form-control input-tag" name="dropLocation" placeholder="Enter Drop Location" />
    </div>

    <div class="span-five">
      <label for="delivery-mode">Delivery Mode</label>
      <select name="deliveryMode" id="delivery-mode" class="form-control select-tag">
        <option value="" selected disabled hidden>Select</option>
        <option value="DOOR">DOOR</option>
        <option value="GODOWN">GODOWN</option>
      </select>
    </div>

    <div class="span-five">
      <label for="delivery-location">Delivery Loc</label>
      <input type="text" id="delivery-location" class="form-control input-tag" name="deliveryLocation" placeholder="Enter Delivery Location" />
    </div>

    <div class="span-six">
      <label for="payment">Payment</label>
      <select name="clientPayment" id="payment" class="form-control select-tag">
        <option value="" selected disabled hidden>Select</option>
        <option value="PAY">PAY</option>
        <option value="TO PAY">TO PAY</option>
      </select>
    </div>      
    </div>

    <input type="hidden" name="objectId" id="object-id">

    <div class="span-full software-options">
          <input type="text" id="self-dispatch" class="form-control input-tag span-full" name="SelfDispatch" value="Self Dispatch" />
    </div>

    <div class="span-full btn-grp">
      <button id="user-submit-btn" class="submit-btn" type="submit">Save User Details</button>
    </div>
  </form>
</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/selectize/dist/js/standalone/selectize.min.js"></script>

<script>
  const clientForm = document.getElementById("client-form");
  const clientSubmitBtn = document.getElementById("client-submit-btn");
  const userForm = document.getElementById("user-form");
  const userSubmitBtn = document.getElementById("user-submit-btn");
  let clientSubmitting = false;
  let userSubmitting = false;

  if (clientForm) {
    clientForm.addEventListener("submit", (e) => {
      if (clientSubmitting) {
        e.preventDefault();
        return;
      }

      if (!clientForm.checkValidity()) return;

      clientSubmitting = true;
      if (clientSubmitBtn) clientSubmitBtn.disabled = true;
    });
  }

  if (userForm) {
    userForm.addEventListener("submit", (e) => {
      if (userSubmitting) {
        e.preventDefault();
        return;
      }

      if (!userForm.checkValidity()) return;

      userSubmitting = true;
      if (userSubmitBtn) userSubmitBtn.disabled = true;
    });
  }
</script>
