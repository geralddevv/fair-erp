</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/selectize/dist/js/standalone/selectize.min.js"></script>

<script>
  const vendorForm = document.getElementById("vendor-form");
  const vendorSubmitBtn = document.getElementById("vendor-submit-btn");
  const vendorUserForm = document.getElementById("vendor-user-form");
  const vendorUserSubmitBtn = document.getElementById("vendor-user-submit-btn");
  let vendorSubmitting = false;
  let vendorUserSubmitting = false;

  if (vendorForm) {
    vendorForm.addEventListener("submit", (e) => {
      if (vendorSubmitting) {
        e.preventDefault();
        return;
      }

      if (!vendorForm.checkValidity()) return;

      vendorSubmitting = true;
      if (vendorSubmitBtn) vendorSubmitBtn.disabled = true;
    });
  }

  if (vendorUserForm) {
    vendorUserForm.addEventListener("submit", (e) => {
      if (vendorUserSubmitting) {
        e.preventDefault();
        return;
      }

      if (!vendorUserForm.checkValidity()) return;

      vendorUserSubmitting = true;
      if (vendorUserSubmitBtn) vendorUserSubmitBtn.disabled = true;
    });
  }


</script>
