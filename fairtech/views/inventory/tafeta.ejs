<% layout('/layout/boilerplate') %>
<!-- The main content -->
<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
  <form
    id="tafeta-form"
    action="/fairdesk/form/tafeta-master"
    method="post"
    class="needs-validation"
    autocomplete="off"
    novalidate
  >
    <div class="span-full form-heading">
      <h1>Tafeta Master</h1>
    </div>

    <div class="span-full form-subheading">
      <h1>Product Details</h1>
    </div>

    <div class="span-five">
      <label for="tafeta-product-id">Product ID</label>
      <input
        type="text"
        value="<%= previewTafetaProductId %>"
        id="tafeta-product-id"
        class="form-control"
        name="tafetaProductId"
        readonly
        required
      />
    </div>

    <div class="span-six">
      <label for="tafeta-material-code">Material Code</label>
      <input
        type="text"
        id="tafeta-material-code"
        class="form-control"
        name="tafetaMaterialCode"
        placeholder="Enter Paper Code"
        required
      />
    </div>

    <div class="span-six">
      <label for="tafeta-material-type">Material Type</label>
      <input
        type="text"
        id="tafeta-material-type"
        class="form-control"
        name="tafetaMaterialType"
        placeholder="Enter Paper Type"
        required
      />
    </div>

    <div class="span-five">
      <label for="tafeta-color">Color</label>
      <select name="tafetaColor" id="tafeta-color" class="form-control select-tag" required>
        <option value="WHITE" selected>WHITE</option>
        <option value="BLUE">BLUE</option>
        <option value="YELLOW">YELLOW</option>
        <option value="PINK">PINK</option>
      </select>
    </div>

    <div class="span-five">
      <label for="tafeta-gsm">GSM</label>
      <input type="text" id="tafeta-gsm" class="form-control" name="tafetaGsm" placeholder="Enter GSM" required />
    </div>

    <div class="span-five">
      <label for="tafeta-width">Width</label>
      <input type="text" id="tafeta-width" class="form-control" name="tafetaWidth" placeholder="Enter Width" required />
    </div>

    <div class="span-dual">
      <label for="tafeta-mtrs">MTRS</label>
      <input type="text" id="tafeta-mtrs" class="form-control" name="tafetaMtrs" placeholder="Enter MTRS" required />
    </div>

    <div class="span-dual">
      <label for="tafeta-core-len">Core Length</label>
      <input
        type="text"
        id="tafeta-core-len"
        class="form-control"
        name="tafetaCoreLen"
        placeholder="Enter Core Length"
        required
      />
    </div>

    <div class="span-dual">
      <label for="tafeta-notch">Notch</label>
      <select name="tafetaNotch" id="tafeta-notch" class="form-control select-tag" required>
        <option value="YES" selected>YES</option>
        <option value="NO">NO</option>
      </select>
    </div>

    <div class="span-dual">
      <label for="tafeta-core-id">Core ID</label>
      <select name="tafetaCoreId" id="tafeta-core-id" class="form-control select-tag" required>
        <option value="0.5">0.5</option>
        <option value="1">1</option>
        <option value="1.5">1.5</option>
        <option value="2">2</option>
        <option value="3" selected>3</option>
      </select>
    </div>

    <input type="hidden" name="userId" id="user-id" />

    <div class="btn-grp span-full">
      <button id="tafeta-submit-btn" type="submit">Save Tafeta</button>
    </div>
  </form>
</div>

<script>
  const tafetaForm = document.getElementById("tafeta-form");
  const tafetaSubmitBtn = document.getElementById("tafeta-submit-btn");
  let tafetaSubmitting = false;

  if (tafetaForm) {
    tafetaForm.addEventListener("submit", (e) => {
      if (tafetaSubmitting) {
        e.preventDefault();
        return;
      }

      if (!tafetaForm.checkValidity()) return;

      tafetaSubmitting = true;
      if (tafetaSubmitBtn) tafetaSubmitBtn.disabled = true;
    });
  }
</script>
