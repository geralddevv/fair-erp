<% layout('/layout/boilerplate') -%>

<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">

  <form
    class="needs-validation"
    action="/fairdesk/tafeta-binding/edit/<%= binding._id %>"
    method="post"
    autocomplete="off"
    novalidate
  >
    <input type="hidden" name="returnTo" value="<%= returnTo || '' %>" />

    <div class="span-full form-subheading gap">
        <h1>Edit Tafeta Binding</h1>
    </div>

    <!-- ================= READ-ONLY INFO ================= -->

    <div class="span-five">
      <label>Tafeta ID</label>
      <input type="text" class="form-control input-tag"
        value="<%= binding.tafetaId?.tafetaProductId || 'N/A' %>" readonly />
    </div>

    <div class="span-five">
      <label>Material Code</label>
      <input type="text" class="form-control input-tag"
        value="<%= binding.tafetaId?.tafetaMaterialCode || '' %>" readonly />
    </div>

    <div class="span-six">
      <label>User Name</label>
      <input type="text" class="form-control input-tag"
        value="<%= binding.userId?.userName || '' %>" readonly />
    </div>

    <div class="span-six">
      <label>Client Name</label>
      <input type="text" class="form-control input-tag"
        value="<%= binding.userId?.clientName || '' %>" readonly />
    </div>

    <!-- ================= TAFETA MASTER SPECS (READ-ONLY) ================= -->

    <div class="span-five">
      <label>Material Type</label>
      <input type="text" class="form-control input-tag"
        value="<%= binding.tafetaId?.tafetaMaterialType || '' %>" readonly />
    </div>

    <div class="span-five">
      <label>Color</label>
      <input type="text" class="form-control input-tag"
        value="<%= binding.tafetaId?.tafetaColor || '' %>" readonly />
    </div>

    <div class="span-six">
      <label>GSM</label>
      <input type="text" class="form-control input-tag"
        value="<%= binding.tafetaId?.tafetaGsm || '' %>" readonly />
    </div>

    <div class="span-five">
      <label>Width</label>
      <input type="text" class="form-control input-tag" id="tafeta-width"
        value="<%= binding.tafetaId?.tafetaWidth || '' %>" readonly />
    </div>

    <div class="span-five">
      <label>MTRS</label>
      <input type="text" class="form-control input-tag" id="tafeta-mtrs"
        value="<%= binding.tafetaId?.tafetaMtrs || '' %>" readonly />
    </div>

    <div class="span-five">
      <label>Core Length</label>
      <input type="text" class="form-control input-tag"
        value="<%= binding.tafetaId?.tafetaCoreLen || '' %>" readonly />
    </div>

    <div class="span-five">
      <label>Notch</label>
      <input type="text" class="form-control input-tag"
        value="<%= binding.tafetaId?.tafetaNotch || '' %>" readonly />
    </div>

    <div class="span-six">
      <label>Core ID</label>
      <input type="text" class="form-control input-tag"
        value="<%= binding.tafetaId?.tafetaCoreId || '' %>" readonly />
    </div>

    <!-- ================= CLIENT SPECIFICATIONS ================= -->

    <div class="span-full form-subheading">
      <h1>Client Specifications</h1>
    </div>

    <div class="span-seven">
      <label>Client Material Code</label>
      <input type="text" name="tafetaClientMaterialCode" class="form-control"
        value="<%= binding.tafetaClientMaterialCode %>" required />
    </div>

    <div class="span-seven">
      <label>Client Material Type</label>
      <input type="text" name="tafetaClientMaterialType" class="form-control"
        value="<%= binding.tafetaClientMaterialType %>" required />
    </div>

    <div class="span-seven">
      <label>Client GSM</label>
      <input type="text" name="clientTafetaGsm" class="form-control"
        value="<%= binding.clientTafetaGsm %>" required />
    </div>

    <div class="span-six">
      <label>MTRS Delivered</label>
      <input type="text" name="tafetaMtrsDel" class="form-control"
        value="<%= binding.tafetaMtrsDel %>" required />
    </div>

    <div class="span-six">
      <label>Rate Per Roll</label>
      <input type="text" name="tafetaRatePerRoll" id="tafeta-rate-per-roll" class="form-control"
        value="<%= binding.tafetaRatePerRoll %>" required />
    </div>

    <div class="span-six">
      <label>Sales sq mtrs Cost</label>
      <input type="text" name="tafetaSaleCost" id="tafeta-sale-cost" class="form-control"
        value="<%= binding.tafetaSaleCost %>" tabindex="-1" required readonly />
    </div>

    <!-- ================= PRICING & ORDER TERMS ================= -->

    <div class="span-full form-subheading">
      <h1>Pricing & Order Terms</h1>
    </div>

    <div class="span-seven">
      <label>Minimum Order QTY</label>
      <input type="text" name="tafetaMinQty" class="form-control"
        value="<%= binding.tafetaMinQty %>" required />
    </div>

    <div class="span-six">
      <label>Order QTY</label>
      <input type="text" name="tafetaOdrQty" class="form-control"
        value="<%= binding.tafetaOdrQty %>" required />
    </div>

    <div class="span-six">
      <label>Repeat Order Freq</label>
      <input type="text" name="tafetaOdrFreq" class="form-control"
        value="<%= binding.tafetaOdrFreq || '' %>" required />
    </div>

    <div class="span-six">
      <label>CR</label>
      <input type="text" name="tafetaCreditTerm" class="form-control"
        value="<%= binding.tafetaCreditTerm || '' %>" required />
    </div>

    <div class="span-seven">
      <label>Status</label>
      <select name="status" class="form-control select-tag" required>
        <option value="ACTIVE" <%= binding.status === "ACTIVE" ? "selected" : "" %>>ACTIVE</option>
        <option value="INACTIVE" <%= binding.status === "INACTIVE" ? "selected" : "" %>>INACTIVE</option>
      </select>
    </div>    

    <!-- ================= BUTTONS ================= -->

    <div class="span-full btn-grp" style="flex-direction: row-reverse;">
      <button class="submit-btn" type="submit">
        Update Tafeta Binding
      </button>
      <button type="button" id="cancelBtn">
        Cancel
      </button>
    </div>

  </form>
</div>

<script>
  document.getElementById("cancelBtn").addEventListener("click", () => {
    window.history.back();
  });

  const widthVal  = Number(document.getElementById("tafeta-width").value)  || 0;
  const mtrsVal   = Number(document.getElementById("tafeta-mtrs").value)   || 0;
  const rateInput = document.getElementById("tafeta-rate-per-roll");
  const costInput = document.getElementById("tafeta-sale-cost");

  function calcSaleCost() {
    const area = (widthVal * mtrsVal) / 1000;
    if (!area || !rateInput.value) return;
    costInput.value = (Number(rateInput.value) / area).toFixed(4);
  }

  rateInput.addEventListener("input", calcSaleCost);
</script>
