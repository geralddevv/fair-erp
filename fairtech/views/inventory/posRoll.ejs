<% layout('/layout/boilerplate') %>
<!-- The main content -->
<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
  <form
    id="pos-roll-form"
    action="/fairdesk/form/pos-roll-master"
    method="post"
    class="needs-validation"
    autocomplete="off"
    novalidate
  >
    <div class="span-full form-heading">
      <h1>POS Roll Master</h1>
    </div>

    <div class="span-full form-subheading">
      <h1>Product Details</h1>
    </div>

    <div class="span-five">
      <label for="pos-product-id">Product ID</label>
      <input
        type="text"
        value="<%= previewPosProductId %>"
        id="pos-product-id"
        class="form-control"
        name="posProductId"
        readonly
        required
      />
    </div>

    <div class="span-four">
      <label for="pos-paper-code">Paper Code</label>
      <input
        type="text"
        id="pos-paper-code"
        class="form-control"
        name="posPaperCode"
        placeholder="Enter Paper Code"
        required
      />
    </div>

    <div class="span-four">
      <label for="pos-paper-type">Paper Type</label>
      <input
        type="text"
        id="pos-paper-type"
        class="form-control"
        name="posPaperType"
        placeholder="Enter Paper Type"
        required
      />
    </div>

    <div class="span-four">
      <label for="pos-color">Color</label>
      <select name="posColor" id=" pos-color" class="form-control select-tag" required>
        <option value="WHITE" selected>WHITE</option>
        <option value="BLUE">BLUE</option>
        <option value="YELLOW">YELLOW</option>
        <option value="PINK">PINK</option>
      </select>
    </div>

    <div class="span-four">
      <label for="pos-gsm">GSM</label>
      <input type="text" id="pos-gsm" class="form-control" name="posGsm" placeholder="Enter GSM" required />
    </div>

    <div class="span-four">
      <label for="pos-width">Width</label>
      <input type="text" id="pos-width" class="form-control" name="posWidth" placeholder="Enter Width" required />
    </div>

    <div class="span-four">
      <label for="pos-mtrs">MTRS</label>
      <input type="text" id="pos-mtrs" class="form-control" name="posMtrs" placeholder="Enter MTRS" required />
    </div>

    <div class="span-three">
      <label for="pos-core-id">Core ID</label>
      <select name="posCoreId" id=" pos-core-id" class="form-control select-tag" required>
        <option value="1">1</option>
        <option value="0.5">0.5</option>
        <option value="2">2</option>
        <option value="3" selected>3</option>
      </select>
    </div>

    <input type="hidden" name="userId" id="user-id" />

    <div class="btn-grp span-full">
      <button id="pos-roll-submit-btn" type="submit">Save POS Roll</button>
    </div>
  </form>
</div>

<script>
  const posRollForm = document.getElementById("pos-roll-form");
  const posRollSubmitBtn = document.getElementById("pos-roll-submit-btn");
  let posRollSubmitting = false;

  if (posRollForm) {
    posRollForm.addEventListener("submit", (e) => {
      if (posRollSubmitting) {
        e.preventDefault();
        return;
      }

      if (!posRollForm.checkValidity()) return;

      posRollSubmitting = true;
      if (posRollSubmitBtn) posRollSubmitBtn.disabled = true;
    });
  }
</script>
