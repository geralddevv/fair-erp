<% layout('/layout/boilerplate') %>
    <style>
      .tafeta-id-success {
      border: 2px solid #28a745 !important;
      background-color: #f3fff6;
      color: #155724;
      font-weight: 600;
    }

    .tafeta-id-error {
      border: 2px solid #dc3545 !important;
      background-color: #fff5f5;
      color: #721c24;
      font-weight: 600;
    }
    </style>

      <!-- The main content -->
      <div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
        <form action="/fairdesk/form/tafeta-binding" method="post" onsubmit="return validateTafetaBeforeSubmit()" class="needs-validation" autocomplete="off" novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="span-full form-heading">
            <h1>Client Tafeta</h1>
          </div>

          <div class="span-full form-subheading">
            <h1>User Info</h1>
          </div>

          <div id="tafeta-id-div" class="span-seven">
            <label for="tafeta-id">Tafeta ID</label>
            <input type="text" id="tafeta-id" class="form-control" name="tafetaProductId" placeholder="Will appear here" readonly required />
          </div>                  

          <div id="client-name-div" class="span-six">
            <div class="clientName-label"><label for="client-name">Client Name</label><span class="asterisk" style="font-size: 14px;"></span></div>
            <select name="clientName" id="client-name" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% for (let client of clients) { %>
              <option value="<%= client %>"><%= client %></option>
              <% } %>
            </select>
          </div>  

          <div id="user-name-div" class="span-six">
            <label>User Name</label>
            <select id="client-user-name" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
            </select>
          </div>
          <div id="user-name-contact-div" class="span-six">
            <label for="user-contact">User Contact</label>
            <input type="text" id="user-contact" class="form-control" name="userContact" placeholder="Enter User Contact" required />
          </div>
          <div id="client-location-div" class="span-seven">
            <label for="client-location">Location</label>
            <input type="text" id="client-location" class="form-control" name="location" placeholder="Enter Location" required />
          </div>

          <div class="span-full form-subheading" style="display: flex; justify-content: space-between; align-items: center;">
            <h1>Tafeta Specifications</h1>
            <button type="button" id="reset-specs-btn" style="padding: 4px 12px; border-radius: 4px; background-color: #dc3545; color: white; border: none; cursor: pointer; font-size: 14px;">
              Reset
            </button>
          </div>

          <div class="span-five">
            <label>Material Code</label>
            <select name="tafetaMaterialCode" id="tafeta-material-code" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% materialCodes?.forEach(pc => { %>
                <option value="<%= pc %>"><%= pc %></option>
              <% }) %>
            </select>
          </div>

          <div class="span-five">
            <label>Material Type</label>
            <select name="tafetaMaterialType" id="tafeta-material-type" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% materialTypes?.forEach(pt => { %>
                <option value="<%= pt %>"><%= pt %></option>
              <% }) %>
            </select>
          </div>

          <div class="span-three">
            <label>Color</label>
            <select name="tafetaColor" id="tafeta-color" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% colors?.forEach(c => { %>
                <option value="<%= c %>"><%= c %></option>
              <% }) %>
            </select>
          </div>

          <div class="span-three">
            <label>GSM</label>
            <select name="tafetaGsm" id="tafeta-gsm" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% gsms?.forEach(g => { %>
                <option value="<%= g %>"><%= g %></option>
              <% }) %>
            </select>
          </div>

          <div class="span-three">
            <label>Width</label>
            <select name="tafetaWidth" id="tafeta-width" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% widths?.forEach(w => { %>
                <option value="<%= w %>"><%= w %></option>
              <% }) %>
            </select>
          </div>

          <div class="span-three">
            <label>MTRS</label>
            <select name="tafetaMtrs" id="tafeta-mtrs" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% mtrsList?.forEach(m => { %>
                <option value="<%= m %>"><%= m %></option>
              <% }) %>
            </select>
          </div>
          
          <div class="span-four">
            <label>Core Length</label>
            <select name="tafetaCoreLen" id="tafeta-core-len" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% coreLens?.forEach(c => { %>
                <option value="<%= c %>"><%= c %></option>
              <% }) %>
            </select>
          </div>

          <div class="span-three">
            <label>Notch</label>
            <select name="tafetaNotch" id="tafeta-notch" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% notches?.forEach(c => { %>
                <option value="<%= c %>"><%= c %></option>
              <% }) %>
            </select>
          </div>          

          <div class="span-three">
            <label for="tafeta-core-id">Core ID</label>
            <select name="tafetaCoreId" id="tafeta-core-id" class="form-control select-tag" required>
              <option value="" disabled selected hidden>Search</option>
              <% coreIds?.forEach(c => { %>
                <option value="<%= c %>"><%= c %></option>
              <% }) %>
            </select>
          </div>

          <div class="span-full form-subheading">
            <h1>Client Overrides</h1>
          </div>
          
          <div class="span-six">
            <label for="tafeta-client-material-code">Client Material Code</label>
            <input type="text" id="tafeta-client-material-code" class="form-control" name="tafetaClientMaterialCode" placeholder="Enter Client Material Code" required />
          </div>
          <div class="span-six">
            <label for="tafeta-client-material-type">Client Material Type</label>
            <input type="text" id="tafeta-client-material-type" class="form-control" name="tafetaClientMaterialType" placeholder="Enter Client Material Type" required />
          </div>
          <div class="span-five">
            <label for="tafeta-client-gsm">Client GSM</label>
            <input type="text" id="tafeta-client-gsm" class="form-control" name="clientTafetaGsm" placeholder="Enter Client GSM" required />
          </div>

          <div class="span-five">
            <label for="tafeta-mtrs-del">MTRS Delivered</label>
            <input type="text" id="tafeta-mtrs-del" class="form-control" name="tafetaMtrsDel" placeholder="Enter MTRS Delivered" required />
          </div>          
          <div class="span-five">
            <label for="tafeta-rate-per-roll">Rate Per Roll</label>
            <input type="text" id="tafeta-rate-per-roll" class="form-control" name="tafetaRatePerRoll" placeholder="Enter rate per roll" required />
          </div>            
          <div class="span-five">
            <label for="tafeta-sale-cost">Sales sq mtrs Cost</label>
            <input type="text" id="tafeta-sale-cost" class="form-control" name="tafetaSaleCost" placeholder="Auto-calculated" tabindex="-1" required readonly />
          </div>           

          <div class="span-full form-subheading">
            <h1>Pricing & Order Terms</h1>
          </div>

          <div class="span-dual">
            <label for="tafeta-min-qty">Minimum Order QTY</label>
            <input type="text" id="tafeta-min-qty" class="form-control" name="tafetaMinQty" placeholder="Enter minimum qty" required />
          </div>
          <div class="span-dual">
            <label for="tafeta-odr-qty">Order QTY</label>
            <input type="text" id="tafeta-odr-qty" class="form-control" name="tafetaOdrQty" placeholder="Enter order qty" required />
          </div>
          <div class="span-dual">
            <label for="tafeta-odr-freq">Repeat Order Freq</label>
            <input type="text" id="tafeta-odr-freq" class="form-control" name="tafetaOdrFreq" placeholder="Enter repeat order frequency" required />
          </div>
          <div class="span-dual">
            <label for="tafeta-credit-term">CR</label>
            <input type="text" id="tafeta-credit-term" class="form-control" name="tafetaCreditTerm" placeholder="Enter credit term" required />
          </div>

          <input type="hidden" name="tafetaId" id="resolved-tafeta-id">
          <input type="hidden" name="userId" id="user-id">

          <div class="btn-grp span-full">
            <button type="submit">Save Tafeta Rating</button>
          </div>          
        </form>
      </div>

<!-- ===== RATE CALCULATION & JS ===== -->
<script src="/js/choices.min.js"></script>
<script>
document.addEventListener("DOMContentLoaded", () => {
  /* ================= ELEMENTS ================= */
  const submitBtn = document.querySelector("button[type='submit']");

  const clientSelect = document.getElementById("client-name");
  const userSelect = document.getElementById("client-user-name");

  const userIdInput = document.getElementById("user-id");
  const userContactInput = document.getElementById("user-contact");
  const locationInput = document.getElementById("client-location");
  const tafetaMtrsInput = document.getElementById("tafeta-mtrs");
  const tafetaMtrsDelInput = document.getElementById("tafeta-mtrs-del");

  const tafetaIdInput = document.getElementById("resolved-tafeta-id");
  const tafetaIdDisplay = document.getElementById("tafeta-id");

  const tafetaFields = [
    "tafeta-material-code",
    "tafeta-material-type",
    "tafeta-color",
    "tafeta-gsm",
    "tafeta-width",
    "tafeta-mtrs",
    "tafeta-core-len",
    "tafeta-notch",
    "tafeta-core-id",
  ];

  const fieldToApiKey = {
    "tafeta-material-code": "materialCodes",
    "tafeta-material-type": "materialTypes",
    "tafeta-color": "colors",
    "tafeta-gsm": "gsms",
    "tafeta-width": "widths",
    "tafeta-mtrs": "mtrsList",
    "tafeta-core-len": "coreLens",
    "tafeta-notch": "notches",
    "tafeta-core-id": "coreIds",
  };

  const fieldToParam = {
    "tafeta-material-code": "tafetaMaterialCode",
    "tafeta-material-type": "tafetaMaterialType",
    "tafeta-color": "tafetaColor",
    "tafeta-gsm": "tafetaGsm",
    "tafeta-width": "tafetaWidth",
    "tafeta-mtrs": "tafetaMtrs",
    "tafeta-core-len": "tafetaCoreLen",
    "tafeta-notch": "tafetaNotch",
    "tafeta-core-id": "tafetaCoreId",
  };

  submitBtn.disabled = true;

  /* ================= CHOICES INIT ================= */
  const clientChoices = new Choices(clientSelect, {
    searchEnabled: true,
    shouldSort: false,
    itemSelectText: "",
  });

  const userChoices = new Choices(userSelect, {
    searchEnabled: true,
    shouldSort: false,
    itemSelectText: "",
  });

  const specChoices = {};
  tafetaFields.forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      specChoices[id] = new Choices(el, {
        searchEnabled: true,
        shouldSort: false,
        itemSelectText: "",
      });
    }
  });

  /* ================= HELPERS ================= */
  function resetUserFields() {
    userIdInput.value = "";
    userContactInput.value = "";
    locationInput.value = "";
  }

  function hardResetUserSelection() {
    userChoices.removeActiveItems();
    userChoices.clearChoices();
    resetUserFields();
  }

  function resetResolvedTafeta() {
    tafetaIdInput.value = "";
    tafetaIdDisplay.value = "";
    submitBtn.disabled = true;
    tafetaIdDisplay.classList.remove("tafeta-id-success", "tafeta-id-error");
  }

  function syncDeliveredMeters() {
    if (!tafetaMtrsInput || !tafetaMtrsDelInput) return;
    const currentMtrs = tafetaMtrsInput.value;
    tafetaMtrsDelInput.value = currentMtrs || "";
  }

  /* ================= SMART FILTER ================= */
  async function filterSpecs(changedFieldId) {
    const params = new URLSearchParams();
    tafetaFields.forEach(id => {
      const el = document.getElementById(id);
      if (el && el.value) {
        params.set(fieldToParam[id], el.value);
      }
    });

    try {
      const res = await fetch(`/fairdesk/form/tafeta-binding/filter-specs?${params}`);
      const data = await res.json();
      if (!data) return;

      const autoSelected = [];

      tafetaFields.forEach(id => {
        if (id === changedFieldId) return; // skip the field that triggered the filter
        const choicesInstance = specChoices[id];
        if (!choicesInstance) return;

        const apiKey = fieldToApiKey[id];
        const filteredValues = data[apiKey] || [];
        const currentValue = document.getElementById(id)?.value || "";

        const newChoices = filteredValues.map(v => ({
          value: String(v),
          label: String(v),
          selected: String(v) === currentValue,
        }));

        // Auto-select if exactly one option and nothing currently selected (and not resetting)
        if (changedFieldId !== "reset-all" && filteredValues.length === 1 && !currentValue) {
          newChoices[0].selected = true;
          autoSelected.push(id);
        }

        choicesInstance.clearStore();
        choicesInstance.setChoices(
          [{ value: "", label: "Search", disabled: true, selected: !newChoices.some(c => c.selected) }, ...newChoices],
          "value",
          "label",
          true
        );
      });

      // If any fields were auto-selected, re-run filter to cascade
      if (autoSelected.length > 0) {
        await filterSpecs(autoSelected[0]);
        resolveTafeta();
      }
    } catch (err) {
      console.error("Filter specs error:", err);
    }
  }

  /* ================= CLIENT → USER ================= */
  clientSelect.addEventListener("change", async () => {
    const clientName = clientSelect.value;
    hardResetUserSelection();

    const res = await fetch(`/fairdesk/form/tafeta-binding/client/${clientName}`);
    const clientData = await res.json();
    if (!clientData || !clientData.users) return;

    if (clientData.users.length === 1) {
      const u = clientData.users[0];
      userChoices.setChoices(
        [{
          value: u._id,
          label: u.userName,
          selected: true,
          customProperties: { mobile: u.userContact || "", location: u.userLocation || "" }
        }],
        "value",
        "label",
        true
      );
      userIdInput.value = u._id;
      userContactInput.value = u.userContact || "";
      locationInput.value = u.userLocation || "";
      return;
    }

    userChoices.setChoices(
      clientData.users.map(u => ({
        value: u._id,
        label: u.userName,
        customProperties: { mobile: u.userContact || "", location: u.userLocation || "" }
      })),
      "value",
      "label",
      true
    );
    resetUserFields();
  });

  /* ================= USER CHANGE ================= */
  userSelect.addEventListener("change", () => {
    const selectedId = userChoices.getValue(true);
    if (!selectedId) return;

    const choice = userChoices._store.choices.find(c => c.value === selectedId);
    if (!choice) return;

    userIdInput.value = choice.value;
    userContactInput.value = choice.customProperties?.mobile || "";
    locationInput.value = choice.customProperties?.location || "";
  });

  /* ================= TAFETA RESOLVE ================= */
  async function resolveTafeta() {
    resetResolvedTafeta();
    syncDeliveredMeters();

    const values = {};
    for (let id of tafetaFields) {
      const el = document.getElementById(id);
      if (!el || !el.value) return;
      values[id] = el.value;
    }

    const params = new URLSearchParams({
      tafetaMaterialCode: values["tafeta-material-code"],
      tafetaMaterialType: values["tafeta-material-type"],
      tafetaColor: values["tafeta-color"],
      tafetaGsm: values["tafeta-gsm"],
      tafetaWidth: values["tafeta-width"],
      tafetaMtrs: values["tafeta-mtrs"],
      tafetaCoreLen: values["tafeta-core-len"],
      tafetaNotch: values["tafeta-notch"],
      tafetaCoreId: values["tafeta-core-id"],
    });

    const res = await fetch(`/fairdesk/form/tafeta-binding/resolve-tafeta?${params}`);

    if (!res.ok) {
      tafetaIdDisplay.value = "No matching Tafeta found";
      tafetaIdDisplay.classList.add("tafeta-id-error");
      return;
    }

    const data = await res.json();

    tafetaIdInput.value = data.tafetaId;
    tafetaIdDisplay.value = data.tafetaProductId;
    tafetaIdDisplay.classList.add("tafeta-id-success");
    submitBtn.disabled = false;

    document.getElementById("tafeta-client-material-code").value = values["tafeta-material-code"];
    document.getElementById("tafeta-client-material-type").value = values["tafeta-material-type"];
    document.getElementById("tafeta-client-gsm").value = values["tafeta-gsm"];
    calcSaleCost();
  }

  /* ================= SPEC CHANGE HANDLER ================= */
  tafetaFields.forEach(id => {
    document.getElementById(id)?.addEventListener("change", async () => {
      await filterSpecs(id);
      resolveTafeta();
    });
  });

  /* ================= RESET SPECS ================= */
  const resetSpecsBtn = document.getElementById("reset-specs-btn");
  if (resetSpecsBtn) {
    resetSpecsBtn.addEventListener("click", async () => {
      // Clear underlying values for tafeta specs & reset their Choices UI
      tafetaFields.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = "";
        
        // Also clear the Choices visible selection
        if (specChoices[id]) {
          specChoices[id].setChoiceByValue("");
        }
      });
      
      resetResolvedTafeta();

      // Clear the overrides if populated
      const clientMaterialCode = document.getElementById("tafeta-client-material-code");
      if (clientMaterialCode) clientMaterialCode.value = "";
      const clientMaterialType = document.getElementById("tafeta-client-material-type");
      if (clientMaterialType) clientMaterialType.value = "";
      const clientGsm = document.getElementById("tafeta-client-gsm");
      if (clientGsm) clientGsm.value = "";

      // Clear all other text inputs
      const otherInputs = [
        "tafeta-mtrs-del",
        "tafeta-rate-per-roll",
        "tafeta-sale-cost",
        "tafeta-min-qty",
        "tafeta-odr-qty",
        "tafeta-odr-freq",
        "tafeta-credit-term"
      ];
      otherInputs.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = "";
      });

      // Reset Client and User dropdowns
      if (typeof clientChoices !== "undefined") {
        clientChoices.setChoiceByValue("");
      }
      hardResetUserSelection();
      
      // Fetch fresh, unfiltered options and apply them to all fields
      await filterSpecs("reset-all");
    });
  }

  /* ================= RATE CALC ================= */
  const widthInput = document.getElementById("tafeta-width");
  const ratePerRollInput = document.getElementById("tafeta-rate-per-roll");
  const saleCostInput = document.getElementById("tafeta-sale-cost");

  function calcSaleCost() {
    if (!widthInput.value || !tafetaMtrsInput.value || !ratePerRollInput.value) return;
    const area = (Number(widthInput.value) * Number(tafetaMtrsInput.value)) / 1000;
    if (!area) return;
    saleCostInput.value = (Number(ratePerRollInput.value) / area).toFixed(4);
  }

  widthInput.addEventListener("input", calcSaleCost);
  tafetaMtrsInput.addEventListener("input", () => {
    syncDeliveredMeters();
    calcSaleCost();
  });
  tafetaMtrsInput.addEventListener("change", syncDeliveredMeters);
  tafetaMtrsInput.addEventListener("addItem", syncDeliveredMeters);
  ratePerRollInput.addEventListener("input", calcSaleCost);
});

/* ================= CUSTOM TOAST ================= */
function showClientToast(message, isError = true) {
  const existingToast = document.getElementById("client-toast");
  if (existingToast) existingToast.remove();

  const toast = document.createElement("div");
  toast.id = "client-toast";
  toast.className = `toast-notification ${isError ? 'toast-error' : 'toast-success'}`;
  toast.innerHTML = `
    <span>${message}</span>
    <span class="toast-close" onclick="this.parentElement.remove()">×</span>
  `;

  document.body.appendChild(toast);

  setTimeout(() => {
    if (toast.parentElement) {
       toast.style.animation = "slideOut 0.5s forwards";
       setTimeout(() => toast.remove(), 500);
    }
  }, 5000);
}

/* ================= FORM GUARD ================= */
function validateTafetaBeforeSubmit() {
  const tafetaId = document.getElementById("resolved-tafeta-id").value;
  if (!tafetaId) {
    showClientToast("Please select a valid Tafeta specification.", true);
    return false;
  }

  const minQty = Number(document.getElementById("tafeta-min-qty").value);
  const odrQty = Number(document.getElementById("tafeta-odr-qty").value);

  if (minQty >= odrQty) {
    showClientToast("Order Quantity must be greater than Minimum Stock Quantity", true);
    return false;
  }

  return true;
}
</script>
